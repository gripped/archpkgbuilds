pkgname=zsnes
pkgver=2.1.0
pkgrel=2
pkgdesc='Super Nintendo emulator'
url='https://github.com/xyproto/zsnes'
arch=(x86_64)
license=(GPL-2.0-only)
depends=(hicolor-icon-theme lib32-libpng lib32-opengl-driver lib32-pipewire lib32-sdl3)
makedepends=(git mesa nasm python)
source=("git+$url#tag=$pkgver")
b2sums=('89a7306ea3bf20dfe0bbb40b3c967d843f4ddf1bb5f07fda5a44e1fe172ced3b8b160b510472d3639544d348a64f49bd7cb8d71ece9024e1b49c0a936a6eb202')

build() {
  # ZSNES is an old 32-bit x86 binary with hand-written Assembly
  # that does not work well with several common flags.
  unset CFLAGS CXXFLAGS LDFLAGS

  export PKG_CONFIG_PATH=/usr/lib32/pkgconfig
  make -C $pkgname
}

package() {
  DESTDIR="$pkgdir" make -C $pkgname install
}
