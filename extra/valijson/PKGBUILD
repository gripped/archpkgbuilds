# Maintainer: Jan Alexander Steffens (heftig) <heftig@archlinux.org>

pkgname=valijson
pkgver=1.1.0
pkgrel=1
pkgdesc="Header-only JSON Schema validation library for C++"
url="https://github.com/tristanpenman/valijson"
arch=(any)
license=(BSD-2-Clause)
depends=(
  boost
)
makedepends=(
  cmake
  git
  ninja
  qt5-base
)
source=("git+$url#tag=v$pkgver")
b2sums=('88e53700aed7587d457a404099a3e9155a3a5afc6e70f44573f179537c9af96b9dd22f1a42c42a01b935a266a80c141a359aa61bfdb5834f72d12da967e960b2')

build() {
  local cmake_options=(
    -D CMAKE_BUILD_TYPE=Release
    -D CMAKE_INSTALL_PREFIX=/usr
  )

  cmake -S valijson -B build -G Ninja "${cmake_options[@]}"
  cmake --build build
}

check() {
  ctest --test-dir build --output-on-failure --stop-on-failure
}

package() {
  DESTDIR="$pkgdir" cmake --install build

  install -Dm644 valijson/LICENSE -t "$pkgdir/usr/share/licenses/$pkgname"
}

