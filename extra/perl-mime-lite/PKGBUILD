# Maintainer: kevin <kevin@archlinux.org>
# Contributor: Eric Johnson <eric@coding-zone.com>

pkgname=perl-mime-lite
pkgver=3.037
pkgrel=1
pkgdesc="Perl module that provides lightweight MIME generator"
arch=('any')
url="https://search.cpan.org/dist/MIME-Lite/"
license=('GPL-1.0-or-later' 'Artistic-1.0-Perl')
depends=('perl-email-date-format' 'perl-mailtools' 'perl-mime-types' 'perl')
options=('!emptydirs')
source=("https://search.cpan.org/CPAN/authors/id/R/RJ/RJBS/MIME-Lite-${pkgver}.tar.gz")
sha512sums=('fda7b616d3add86849d8f6fddbc05fdbedbb1770fe083d116757185375a7917e3d5cef39ac414ccb0a46bc1ac6e71f361983e85f83f0e277ef611925cee0ad97')

build() {
  cd MIME-Lite-${pkgver}
  perl Makefile.PL INSTALLDIRS=vendor
  make
}

check() {
  cd MIME-Lite-${pkgver}
  make test
}

package() {
  cd MIME-Lite-${pkgver}
  make DESTDIR="${pkgdir}" install
}
