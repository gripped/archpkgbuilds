# Maintainer: Jakub Klinkovský <lahwaacz at archlinux dot org>

_name=nvidia-ml-py
pkgname=python-$_name
pkgver=13.590.48
pkgrel=2
pkgdesc='Python bindings for the NVIDIA Management Library (NVML)'
arch=(any)
url='https://pypi.org/project/nvidia-ml-py'
license=(BSD-3-Clause)
depends=(
  nvidia-utils
  python
)
makedepends=(
  python-build
  python-installer
  python-setuptools
  python-wheel
)
source=(https://files.pythonhosted.org/packages/source/${_name::1}/$_name/${_name//-/_}-$pkgver.tar.gz)
b2sums=('9884aa233034add46afd7d6ab03b261868050963c9e5814ccad7b54d928c63aa096f314b6f73bcc39e6870e57df118ca89e6446126d1f0734f79d565b4f66865')

prepare() {
  cd ${_name//-/_}-$pkgver
  # Extract the license which is included at the end of the README.txt file
  grep -A 999999 "COPYRIGHT" README.txt > LICENSE
}

build() {
  cd ${_name//-/_}-$pkgver
  python -m build --wheel --no-isolation
}

package() {
  cd ${_name//-/_}-$pkgver
  python -m installer --destdir="$pkgdir" dist/*.whl

  # Install the license
  install -vDm 644 LICENSE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE

  # Move example.py to correct location
  local site_packages=$(python -c "import site; print(site.getsitepackages()[0])")
  install -vdm 755 "$pkgdir"/usr/share/doc/$pkgname/
  mv -v "$pkgdir$site_packages"/example.py "$pkgdir"/usr/share/doc/$pkgname/
  rm -v "$pkgdir$site_packages"/__pycache__/example.*
}
