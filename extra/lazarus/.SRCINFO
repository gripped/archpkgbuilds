pkgbase = lazarus
	pkgver = 4.6
	pkgrel = 1
	url = http://www.lazarus.freepascal.org/
	arch = x86_64
	license = GPL-2.0-or-later
	license = LGPL-2.1-or-later
	license = MPL-1.1
	makedepends = fpc
	makedepends = fpc-src
	makedepends = qt5pas
	makedepends = qt6pas
	makedepends = rsync
	options = !makeflags
	options = libtool
	options = staticlibs
	options = !strip
	source = https://gitlab.com/freepascal.org/lazarus/lazarus/-/archive/lazarus_4_6/lazarus-lazarus_4_6.tar.bz2
	sha512sums = 9f59a21d38b36416757b6572ebfa10dba13457fc7a5fd9c91550ea2d1b1daed7c9cc292bd7069a8dd1ac3a8ca2c8231f0456a0fe89f011a92d07a861e0f14684

pkgname = lazarus
	pkgdesc = Delphi-like IDE for FreePascal common files
	depends = fpc
	depends = fpc-src
	depends = gdb
	optdepends = perl: to run some scripts in the tools directory
	optdepends = qt5pas: to compile Qt5 apps
	optdepends = qt6pas: to compile Qt6 apps

pkgname = lazarus-qt5
	pkgdesc = Delphi-like IDE for FreePascal Qt5 version
	depends = lazarus
	depends = qt5pas
	conflicts = lazarus-gtk2
	conflicts = lazarus-gtk3
	conflicts = lazarus-qt6
	replaces = lazarus-qt
	replaces = lazarus-qt4

pkgname = lazarus-qt6
	pkgdesc = Delphi-like IDE for FreePascal Qt6 version
	depends = lazarus
	depends = qt6pas
	conflicts = lazarus-gtk2
	conflicts = lazarus-gtk3
	conflicts = lazarus-qt5
	replaces = lazarus-gtk3
