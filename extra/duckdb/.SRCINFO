pkgname = duckdb

pkgname = python-duckdb
	pkgdesc = An analytical in-process SQL database management system Python API
	depends = glibc
	depends = libgcc
	depends = libstdc++
	depends = python
	depends = python-typing_extensions
	optdepends = ipython: used in duckdb.query_graph
	optdepends = python-fsspec: used in duckdb.filesystem
	optdepends = python-numpy: used in duckdb.experimental.spark and in duckdb.fetchnumpy()
	optdepends = python-pandas: used for pandas dataframes all over the place
	optdepends = python-pyarrow: used for pyarrow support
	optdepends = python-arrow-adbc: for the adbc driver
