# Maintainer: Antonio Rojas <arojas@archlinux.org>
# Contributor: Rémy Oudompheng <oudomphe@clipper.ens.fr>

pkgname=singular
_majver=4-4-1
_patchver=p5
_pkgver=${_majver}${_patchver}
pkgver=${_majver//-/.}${_patchver/p/.p}
pkgrel=7
pkgdesc='Computer Algebra System for polynomial computations'
arch=(x86_64)
url='https://www.singular.uni-kl.de/'
license=(GPL-2.0-only
         GPL-3.0-only)
depends=(bash
         cddlib
         flint
         glibc
         gmp
         libgcc
         libstdc++
         ntl
         readline)
makedepends=(4ti2
             git
             latex2html
             lrcalc
             normaliz
             sharutils
             texlive-basic
             texlive-bin
             texlive-latex)
optdepends=('normaliz: Normaliz interface')
provides=(singular-factory)
source=(git+https://github.com/Singular/Singular#tag=Release-$_pkgver
        fix-factorization.patch)
sha256sums=('77e0553ac6cfba06fccf1e9173e9a3a297e8a922a7017d5d6af237921485f1d3'
            '4761b1968d889366f9b0a640c44c83f58d7e406901fcf4b22393ca7886ca5855')
options=(!zipman)
#_srcdir=singular-${_majver//-/.}
_srcdir=Singular

prepare() {
  cd $_srcdir
  git cherry-pick -n 56681f1c0a4f6fd9f61fe6241c536aad592c8478 # Fix crashes
  patch -p1 -i ../fix-factorization.patch # https://github.com/Singular/Singular/issues/1334
  ./autogen.sh
}

build() {
  cd $_srcdir

  ./configure \
    --prefix=/usr \
    --libexecdir=/usr/lib \
    --enable-bigintm-module \
    --enable-bigintm-module \
    --enable-Order-module \
    --enable-python-module \
    --enable-gfanlib-module \
    --enable-polymake-module \
    --enable-doc-build
# https://bugzilla.gnome.org/show_bug.cgi?id=655517
  sed -e 's/ -shared / -Wl,-O1,--as-needed\0/g' -i libtool -i */libtool
  make
  make -C doc doc.tbz2
}

check() {
  cd $_srcdir
  make check
}
  
package() {
  cd $_srcdir
  make DESTDIR="$pkgdir" install
}
