# Maintainer: Felix Yan <felixonmars@archlinux.org>
# Contributor: Bence Balint <balintbence1337@gmail.com>

pkgname=python-w3lib
pkgver=2.3.0
pkgrel=1
pkgdesc="Library of web-related functions"
arch=('any')
license=('BSD-3-Clause')
url="https://github.com/scrapy/w3lib"
depends=('python')
makedepends=('git' 'python-setuptools')
checkdepends=('python-pytest')
source=("git+https://github.com/scrapy/w3lib.git#tag=v$pkgver")
sha512sums=('2f87875bec102450a12dd911e12719af1df478f9eaa2d329f76c85126bad2b62c36ad3a8bff775c2da86f5da583417df810c0323b585ccaafc7f619da34d24f0')

build() {
  cd w3lib
  python setup.py build
}

check() {
  cd w3lib
  pytest
}

package() {
  cd w3lib
  python setup.py install --root="$pkgdir" --optimize=1
  install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}
