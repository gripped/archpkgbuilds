# Maintainer: Jakub Klinkovský <lahwaacz at archlinux dot org>

_name=numba-cuda
pkgname=python-$_name
pkgver=0.28.2
pkgrel=1
pkgdesc="The CUDA target for Numba"
url="https://github.com/NVIDIA/numba-cuda"
arch=(x86_64)
license=(BSD-2-Clause)
depends=(
  glibc
  libgcc
  libstdc++
  python
  python-cuda-bindings
  python-cuda-core
  python-cuda-pathfinder
  python-llvmlite
  python-numba
  python-numpy
  python-packaging
  python-yaml
)
makedepends=(
  python-build
  python-installer
  python-setuptools
  python-wheel
)
optdepends=(
  'python-colorama: colors in error messages'
  'python-pygments: syntax highlighting in code dumps'
)
source=($pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz)
b2sums=('2c103388374b5166ce15e2261937f163f08d8ad76da89a7c51d180966e5ee267f000cf7a33166b18cd6d5c4e6c3256e1f94a99f1af2f0a311ca626871a2e7b46')

build() {
  cd $_name-$pkgver
  python -m build --wheel --no-isolation
}

package() {
  cd $_name-$pkgver
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -vDm 644 LICENSE LICENSE.numba -t "$pkgdir"/usr/share/licenses/$pkgname/
  # Remove tests
  rm -rv "$pkgdir"$(python -c "import site; print(site.getsitepackages()[0])")/numba_cuda/numba/cuda/{tests/,testing.py}
}
