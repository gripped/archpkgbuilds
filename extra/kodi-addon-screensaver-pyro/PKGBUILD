# Maintainer: BlackEagle <ike.devolder@gmail.com>>

pkgname=kodi-addon-screensaver-pyro
epoch=1
pkgver=21.0.2
_codename=Omega
pkgrel=2
pkgdesc="Pyro screensaver for Kodi"
arch=('x86_64')
url='https://github.com/xbmc/screensaver.pyro'
license=('GPL-2.0-or-later')
groups=('kodi-addons' 'kodi-addons-screensaver')
makedepends=('git' 'cmake' 'kodi-dev')
options=(!lto)
source=("$pkgname-$pkgver.tar.gz::https://github.com/xbmc/screensaver.pyro/archive/$pkgver-$_codename.tar.gz")
sha512sums=('d9ddcc4a2db3feb37a7852b30d3965756c67989c86f698d3138258d12e46617cb9adf5c45d3099818f07c85255a58ee51c900bf4cd0077874dbfe920fa8cb59d')

build() {
    cd "screensaver.pyro-$pkgver-$_codename"
    cmake \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_SHARED_LIBS=1 \
        -DUSE_LTO=1 \
        .
    make
}

package() {
    depends=('kodi')
    cd "screensaver.pyro-$pkgver-$_codename"
    make DESTDIR="$pkgdir/" install
}

