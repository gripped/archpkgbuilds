# Maintainer: Felix Yan <felixonmars@archlinux.org>

pkgname=scmpuff
pkgver=0.6.1
pkgrel=1
pkgdesc="Numeric file shortcuts for common git commands"
arch=('x86_64')
url="https://github.com/mroth/scmpuff"
license=('MIT')
depends=('glibc')
makedepends=('go' 'git')
source=("git+https://github.com/mroth/scmpuff.git#tag=v$pkgver")
sha512sums=('4bbf59ca37581dab2dd3696ab2dbd76c61caa24b4ef0bd39325bdf63db31d1e052573ae1e84941cb8bf72e1e1b5a9c445661ce2268b3e2c6a3638a8f68af05a5')

build() {
  cd scmpuff
  export GOFLAGS="-buildmode=pie -trimpath -ldflags=-linkmode=external"
  export CGO_LDFLAGS="${LDFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CPPFLAGS="${CPPFLAGS}"
  go build -o scmpuff
}

check() {
  cd scmpuff
  go test ./...
}

package() {
  cd scmpuff
  install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/scmpuff/
  install -Dm755 scmpuff -t "$pkgdir"/usr/bin/
}
