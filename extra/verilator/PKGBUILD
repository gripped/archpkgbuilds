pkgname=verilator
pkgver=5.042
pkgrel=1
pkgdesc='The fastest free Verilog HDL simulator'
url='https://www.veripool.org/verilator/'
arch=('x86_64')
license=('LGPL-3.0-or-later')
depends=('perl' 'python')
optdepends=('systemc')
makedepends=('git' 'help2man' 'systemc')
checkdepends=('python-distro')
source=("git+https://github.com/verilator/verilator.git#tag=v$pkgver")
sha512sums=('3de683c95aa3f70236eb78c458f3cb11602e12af70a734114bfd041fa41c36fba46c5470b7e66e3cba40a16fc9e6ad0478a003e947d0a633d854ad24c7b81c21')

prepare() {
  cd verilator
  autoconf
}

build() {
  cd verilator
  ./configure --prefix=/usr
  make
}

check() {
  cd verilator
  make test
}

package() {
  cd verilator
  make install DESTDIR="$pkgdir"
}
