pkgname=verilator
pkgver=5.046
pkgrel=1
pkgdesc='The fastest free Verilog HDL simulator'
url='https://www.veripool.org/verilator/'
arch=('x86_64')
license=('LGPL-3.0-only' 'Artistic-2.0')
depends=('perl' 'python')
optdepends=('systemc')
makedepends=('git' 'help2man' 'systemc')
checkdepends=('python-distro')
source=("git+https://github.com/verilator/verilator.git#tag=v$pkgver")
sha512sums=('b708df3f43ef0095408eae96eca3a0be3301279d421a86f5b55078a25b5849ece69b56884b942150f4e6db79e649a583301564e5bf8944f0d14d469b8ca48c61')

prepare() {
  cd verilator
  autoconf
}

build() {
  cd verilator
  ./configure --prefix=/usr
  make
}

check() {
  cd verilator
  make test
}

package() {
  cd verilator
  make install DESTDIR="$pkgdir"
}
