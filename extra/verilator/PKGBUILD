pkgname=verilator
pkgver=5.044
pkgrel=1
pkgdesc='The fastest free Verilog HDL simulator'
url='https://www.veripool.org/verilator/'
arch=('x86_64')
license=('LGPL-3.0-or-later')
depends=('perl' 'python')
optdepends=('systemc')
makedepends=('git' 'help2man' 'systemc')
checkdepends=('python-distro')
source=("git+https://github.com/verilator/verilator.git#tag=v$pkgver")
sha512sums=('731fee122383ed1e1bebf96cdf70b3ed12a8d32d905629caad4e79dd9918ba716785f7d480e3d66831f00d71100abb081570d03d14c2d1338d006bf23f15a2a4')

prepare() {
  cd verilator
  autoconf
}

build() {
  cd verilator
  ./configure --prefix=/usr
  make
}

check() {
  cd verilator
  make test
}

package() {
  cd verilator
  make install DESTDIR="$pkgdir"
}
