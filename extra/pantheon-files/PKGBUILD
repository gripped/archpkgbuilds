# Maintainer: Maxime Gauduin <alucryd@archlinux.org>

pkgname=pantheon-files
pkgver=7.2.0
pkgrel=1
pkgdesc='The Pantheon File Browser'
arch=(x86_64)
url=https://github.com/elementary/files
license=(GPL-3.0-only)
groups=(pantheon)
depends=(
  atk
  bash
  cairo
  dconf
  gdk-pixbuf2
  glib2
  glibc
  gtk3
  gvfs
  libcanberra
  libcloudproviders
  libgee
  libgit2-glib
  libgranite.so
  libhandy-1.so
  libnotify
  libportal
  libportal-gtk3
  pango
  sqlite
  zeitgeist
)
makedepends=(
  cmake
  flatpak-builder
  git
  gnome-common
  meson
  vala
)
optdepends=(
  'contractor: Various context menu entries'
  'tumbler: Thumbnails generation'
)
_tag=3525b3f9ac18756ba76769dcaa012ca53274ec23
source=(pantheon-files::git+https://github.com/elementary/files.git#tag=${_tag})
b2sums=('7d5dc8e9e7c55e438cf0c8e12105e72d2d2fe6ec3044e4d3b5bdf18ae83630573491557361a63318cbf19123904e6def0444970b12bd7697f2387dfccf17f269')

pkgver() {
  cd pantheon-files
  git describe --tags
}

build() {
  export CFLAGS+=" -Wno-implicit-function-declaration"
  arch-meson pantheon-files build
  ninja -C build
}

package() {
  DESTDIR="${pkgdir}" ninja -C build install
}

