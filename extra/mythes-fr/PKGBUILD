# Contributor: Guillaume ALAUX <guillaume@archlinux.org>

pkgname=mythes-fr
pkgver=2.3
pkgrel=5
_commit=3fc3d99f071693dd40a78ba1f729ef47dc189692
_name=dictionaries
pkgdesc="French thesaurus"
arch=('any')
url="https://www.dicollecte.org/"
license=(LGPL-2.1-or-later)
makedepends=(
  git
  libmythes
)
optdepends=('libmythes: offers thesaurus library functions')
source=(git+https://anongit.freedesktop.org/git/libreoffice/dictionaries.git#commit=$_commit)
sha256sums=('69555e2702e5807c2b43aa1c0c3b463875d939742c4b9f5e8ba0fd7eb5534e79')

build() {
  th_gen_idx.pl > $_name/fr_FR/thes_fr.idx < $_name/fr_FR/thes_fr.dat
}

package() {
  local aliases=(fr_BE fr_CA fr_CH fr_LU)
  local lang file

  install -vDm 644 $_name/fr_FR/thes_fr.dat "$pkgdir/usr/share/mythes/th_fr_FR_v2.dat"
  install -vDm 644 $_name/fr_FR/thes_fr.idx "$pkgdir/usr/share/mythes/th_fr_FR_v2.idx"
  install -vdm 755 "$pkgdir/usr/share/myspell/dicts/"

  for lang in "${aliases[@]}"; do
    ln -sv th_fr_FR_v2.idx "$pkgdir/usr/share/mythes/th_${lang}_v2.idx"
    ln -sv th_fr_FR_v2.dat "$pkgdir/usr/share/mythes/th_${lang}_v2.dat"
  done

  for file in "$pkgdir/usr/share/mythes/"*; do
    ln -sv "/usr/share/mythes/$(basename $file)" "$pkgdir/usr/share/myspell/dicts/$(basename $file)"
  done

  # docs
  install -vDm 644 $_name/fr_FR/README*.txt -t "$pkgdir/usr/share/doc/$pkgname/"
}
