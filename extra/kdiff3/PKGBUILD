pkgname=kdiff3
pkgver=1.12.4
pkgrel=1
pkgdesc='A file comparator/merge tool'
arch=(x86_64)
url='https://apps.kde.org/kdiff3/'
license=(GPL-2.0-or-later)
depends=(glibc
         icu
         kconfig
         kcoreaddons
         kconfigwidgets
         kcrash
         ki18n
         kio
         kwidgetsaddons
         kxmlgui
         libgcc
         libstdc++
         qt6-base)
makedepends=(boost
             extra-cmake-modules
             kdoctools)
source=(https://download.kde.org/stable/$pkgname/$pkgname-$pkgver.tar.xz{,.sig})
sha256sums=('4690a35aa933b192751dd590a6b4f53fef3aa950246371112ad6e872f6b26ecb'
            'SKIP')
validpgpkeys=(EE56D710885D36FB1E4D21F3F442B36D614B06BC) # Michael Reeves <reeves.87@gmail.com>

build() {
  cmake -B build -S $pkgname-$pkgver \
    -DCMAKE_BUILD_TYPE=None
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
