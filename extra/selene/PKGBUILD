# Maintainer: Daniel M. Capella <polyzen@archlinux.org>
# Maintainer: Caleb Maclennan <caleb@alerque.com>

pkgname=selene
pkgver=0.30.1
pkgrel=1
pkgdesc='Blazing-fast modern Lua linter written in Rust'
arch=(x86_64)
url=https://github.com/Kampfkarren/selene
license=(MPL-2.0)
depends=(
  gcc-libs
  glibc
  openssl
)
makedepends=(
  cargo
  git
)
options=(!lto)
source=("git+$url.git#tag=$pkgver")
b2sums=('e06e20b9ee7cc6ed0d96d56a2fc86b3a4f2f8668b263f863f7553ea6162a93a3488345a304efa7eada75aa5b40adcee96539b8f4e1d49a1ffcb5a98feb671329')

prepare() {
  cd $pkgname
  cargo fetch --locked --target "$(rustc --print host-tuple)"
}

build() {
  cd $pkgname
  cargo build --release --locked --offline
}

check() {
  cd $pkgname
  cargo test --locked --offline
}

package() {
  cd $pkgname
  install -Dt "$pkgdir"/usr/bin target/release/$pkgname
}

