# Maintainer: kpcyrd <kpcyrd[at]archlinux[dot]org>

pkgname=worker-build
pkgver=0.7.5
pkgrel=1
pkgdesc="Custom build command for a Cloudflare Workers project"
url='https://github.com/cloudflare/workers-rs/tree/main/worker-build'
arch=('x86_64')
license=('Apache-2.0')
depends=(
  'esbuild'
  'glibc'
  'libgcc'
  'openssl' 'libcrypto.so' 'libssl.so'
  'wasm-bindgen'
  'wasm-pack'
)
makedepends=('cargo')
options=('!lto')
source=("${pkgname}-${pkgver}.tar.gz::https://crates.io/api/v1/crates/${pkgname}/${pkgver}/download")
sha256sums=('95831ee9a995172acf3b75f7a8fa6fe115e88570329e06974e0aac4221b224ff')
b2sums=('99021c3cb0b093940cada7352bc8a3a805b10dbf44b74712ad53fc9bd9864da3667e971ac353b54b7e1b8e1a4ee1123333ef941b02b4bb28c0ef9c4719c708b3')

prepare() {
  cd ${pkgname}-${pkgver}
  cargo fetch --locked --target "$(rustc --print host-tuple)"
}

build() {
  cd ${pkgname}-${pkgver}
  cargo build --frozen --release
}

check() {
  cd ${pkgname}-${pkgver}
  cargo test --frozen
}

package() {
  cd ${pkgname}-${pkgver}
  install -Dm 755 -t "${pkgdir}/usr/bin" target/release/worker-build
}

