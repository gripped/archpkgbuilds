# Maintainer: Felix Yan <felixonmars@archlinux.org>

pkgname=ananta
pkgver=1.3.3
pkgrel=1
pkgdesc="A command-line tool to execute commands on multiple remote hosts"
arch=('any')
url="https://sr.ht/~cwt/ananta/"
license=('MIT')
depends=('python-asyncssh' 'python-urwid')
optdepends=('python-uvloop: for improved performance')
makedepends=('git' 'python-build' 'python-installer' 'python-poetry-core')
checkdepends=('python-pytest' 'python-pytest-asyncio')
source=("git+https://github.com/cwt/ananta.git#tag=v$pkgver")
sha512sums=('bc48916ff3177945d1094a4e6b9a6f9bed332300a54c212da5568b4a77bf1db28bbee70a40c716f9c5215caaaaa7e6b08f02b75af747a465a3364c4665702f94')

build() {
  cd ananta
  python -m build --wheel --no-isolation
}

check() {
  cd ananta
  python -m venv --system-site-packages venv
  venv/bin/python -m installer dist/*.whl
  venv/bin/python -m pytest
}

package() {
  cd ananta
  python -m installer --destdir="$pkgdir" dist/*.whl
}
