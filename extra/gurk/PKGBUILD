# Maintainer: kpcyrd <kpcyrd[at]archlinux[dot]org>
# Maintainer: Caleb Maclennan <caleb@alerque.com>

pkgname=gurk
pkgver=0.9.0
pkgrel=1
pkgdesc="Signal Messenger client for terminal"
url='https://github.com/boxdot/gurk-rs'
arch=('x86_64')
license=('AGPL-3.0-only')
depends=(
  glibc # libc.so libm.so
  libgcc libgcc_s.so
  sqlcipher # libsqlcipher.so
)
makedepends=(
  'cargo'
  'protobuf'
)
replaces=('gurk-bin')
options=(!lto)
source=(https://github.com/boxdot/${pkgname}-rs/archive/v${pkgver}/${pkgname}-${pkgver}.tar.gz)
sha256sums=('859f0583492ebf302988102fc1c2051a7df57d626b4408b73d78ac064296f067')
b2sums=('b1e4209b2de8f30f4c82e1c545629dbfa92c60aee747cc75cd2406159656f3f7f6261ffb960ef8bcbd7ac671bee9425d9d87d1db6c51446ab766923aa80f44c6')

prepare() {
  cd "${pkgname}-rs-${pkgver}"
  cargo fetch --locked --target host-tuple
}

build() {
  cd "${pkgname}-rs-${pkgver}"
  LIBSQLITE3_SYS_USE_PKG_CONFIG=1 cargo build --frozen --release
}

check() {
  cd "${pkgname}-rs-${pkgver}"
  LIBSQLITE3_SYS_USE_PKG_CONFIG=1 cargo test --frozen
  target/release/gurk --help
}

package() {
  cd "${pkgname}-rs-${pkgver}"
  install -Dm 755 -t "${pkgdir}/usr/bin" \
    target/release/gurk
}

