pkgname=go-task
pkgver=3.49.1
pkgrel=1
pkgdesc='A task runner written in Go'
arch=(x86_64)
url='https://taskfile.dev'
license=(MIT)
depends=(glibc)
makedepends=(git go)
install=go-task.install
source=(
  "$pkgname::git+https://github.com/go-task/task#tag=v$pkgver"
  rename-completions.patch
  fix-version.patch
)
