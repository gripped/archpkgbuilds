pkgname=wordpress
pkgver=6.9.4
pkgrel=1
pkgdesc='Blog tool and publishing platform'
arch=(any)
url='https://wordpress.org/'
license=(GPL-2.0-or-later)
depends=(php-interpreter)
optdepends=('apache: Web server'
            'mariadb: Database server'
            'nginx: Web server')
options=(!debug emptydirs)
install=$pkgname.install
source=("https://wordpress.org/$pkgname-$pkgver.tar.gz")
sha256sums=('db610ad9f549e0abb5af3e3d5c6729c58d874439654cdf0afea425b2ea895f35')
b2sums=('5a4dc62a7652cfb196d77c1e7c8b46f7a5e95481948dcfc9ace7a7be1894b099403cdf10bd5d4b5de90f2fc33e59bd1eb706f94425bfd995eb788faf0f71affd')

package() {
  install -d "$pkgdir/usr/share/webapps"
  cp -r $pkgname "$pkgdir/usr/share/webapps"
}
