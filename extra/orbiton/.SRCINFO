pkgbase = orbiton
	pkgdesc = Configuration-free text editor and IDE
	pkgver = 2.73.0
	pkgrel = 1
	url = https://roboticoverlords.org/orbiton/
	arch = x86_64
	license = BSD-3-Clause
	makedepends = git
	makedepends = go
	makedepends = vte3
	depends = glibc
	options = !lto
	source = git+https://github.com/xyproto/orbiton#tag=v2.73.0
	b2sums = 6e77160cfdbdbbe84f48f86addfb70abad21b2bb032fcde1492c9910230fcc426dae544ad339520421c73f27b6bad0f07975e7531e85d7946bca270886fb4430

pkgname = orbiton
	optdepends = abcmidi: for writing music in the ABC notation
	optdepends = agda: for compiling Agda
	optdepends = asciidoctor: for writing man pages
	optdepends = astyle: for formatting C#
	optdepends = clang: for formatting C, C++ and Objective-C with clang-format
	optdepends = clojure: for compiling Clojure
	optdepends = cmake: for building CMake projects
	optdepends = crystal: for compiling and formatting Crystal
	optdepends = dart: for compiling and formatting Dart
	optdepends = delve: for debugging Go
	optdepends = erlang: for compiling Erlang
	optdepends = fpc: for compiling and formatting Object Pascal
	optdepends = gcc-d: for compiling D
	optdepends = gcc-fortran: for compiling Fortran
	optdepends = gdb: for debugging
	optdepends = ghc: for compiling and running Haskell
	optdepends = gopls: for Tab completing Go
	optdepends = guile: for running Scheme
	optdepends = haskell-ormolu: for formatting Haskell
	optdepends = jad: for decompiling .class files on the fly
	optdepends = java-environment: for compiling Java
	optdepends = just: for formatting and running justfiles
	optdepends = kotlin: for compiling Kotlin
	optdepends = ktlint: for formatting Kotlin
	optdepends = lilypond: for typesetting music
	optdepends = lua: for compiling and running Lua
	optdepends = mlton: for compiling Standard ML
	optdepends = mono: for compiling C#
	optdepends = nasm: for compiling Assembly
	optdepends = nim: for compiling Nim
	optdepends = ocaml: for compiling and formatting OCaml
	optdepends = odin: for compiling Odin
	optdepends = odinfmt: for formatting Odin
	optdepends = ollama: for explaining code
	optdepends = pandoc: for exporting Markdown to PDF
	optdepends = perl-tidy: for formatting Perl
	optdepends = prettier: for formatting JavaScript, TypeScript and CSS
	optdepends = pylsp: for Tab completing Python
	optdepends = python-poetry: for running Poetry and Flask projects
	optdepends = python-ruff: for formatting Python
	optdepends = ruby: for running Ruby
	optdepends = ruby-rubocop: for formatting Ruby
	optdepends = rust-analyzer: for Tab completing Rust
	optdepends = rustup: for compiling and formatting Rust
	optdepends = scdoc: for writing man pages
	optdepends = shfmt: for formatting Shell scripts
	optdepends = stylua: for formatting Lua
	optdepends = tidy: for formatting HTML and XML
	optdepends = timidity: for playing music in the ABC notation
	optdepends = wl-clipboard: for copy-paste on Wayland
	optdepends = xclip: for copy-paste on X11
	optdepends = yasm: for compiling Assembly
	optdepends = zig: for compiling and formatting Zig
	optdepends = zls: for Tab completing Zig

pkgname = orbiton-gtk3
	pkgdesc = Configuration-free text editor and IDE (GTK3/VTE3)
	depends = glibc
	depends = orbiton
	depends = vte3

pkgname = orbiton-nano
	pkgdesc = Configuration-free text editor and IDE (Nano/Pico Mode)
	depends = glibc
	depends = orbiton
	provides = nano
	conflicts = nano
