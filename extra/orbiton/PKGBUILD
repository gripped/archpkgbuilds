# Maintainer: Alexander F. Rødseth <xyproto@archlinux.org>

pkgbase=orbiton
pkgname=(orbiton orbiton-gtk3 orbiton-nano)
pkgver=2.73.0
pkgrel=1
pkgdesc='Configuration-free text editor and IDE'
arch=(x86_64)
url='https://roboticoverlords.org/orbiton/'
license=(BSD-3-Clause)
makedepends=(git go vte3)
depends=(glibc)
options=(!lto)
source=("git+https://github.com/xyproto/orbiton#tag=v$pkgver")
b2sums=('6e77160cfdbdbbe84f48f86addfb70abad21b2bb032fcde1492c9910230fcc426dae544ad339520421c73f27b6bad0f07975e7531e85d7946bca270886fb4430')

build() {
  export LDFLAGS="$(echo $LDFLAGS | sed 's/ -Wl//g;s/,--sort-common//')"
  make -C $pkgbase o gui
}

package_orbiton() {
  # TODO: consider moving one or more of these from AUR:
  # 'elm-bin: for compiling Elm'
  # 'gnucobol: for compiling COBOL'
  # 'google-java-format: for formatting Java'
  # 'hare: for compiling Hare'
  # 'scala: for compiling Scala'
  # 'vlang: for compiling and formatting V'
  optdepends=('abcmidi: for writing music in the ABC notation'
              'agda: for compiling Agda'
              'asciidoctor: for writing man pages'
              'astyle: for formatting C#'
              'clang: for formatting C, C++ and Objective-C with clang-format'
              'clojure: for compiling Clojure'
              'cmake: for building CMake projects'
              'crystal: for compiling and formatting Crystal'
              'dart: for compiling and formatting Dart'
              'delve: for debugging Go'
              'erlang: for compiling Erlang'
              'fpc: for compiling and formatting Object Pascal'
              'gcc-d: for compiling D'
              'gcc-fortran: for compiling Fortran'
              'gdb: for debugging'
              'ghc: for compiling and running Haskell'
              'gopls: for Tab completing Go'
              'guile: for running Scheme'
              'haskell-ormolu: for formatting Haskell'
              'jad: for decompiling .class files on the fly'
              'java-environment: for compiling Java'
              'just: for formatting and running justfiles'
              'kotlin: for compiling Kotlin'
              'ktlint: for formatting Kotlin'
              'lilypond: for typesetting music'
              'lua: for compiling and running Lua'
              'mlton: for compiling Standard ML'
              'mono: for compiling C#'
              'nasm: for compiling Assembly'
              'nim: for compiling Nim'
              'ocaml: for compiling and formatting OCaml'
              'odin: for compiling Odin'
              'odinfmt: for formatting Odin'
              'ollama: for explaining code'
              'pandoc: for exporting Markdown to PDF'
              'perl-tidy: for formatting Perl'
              'prettier: for formatting JavaScript, TypeScript and CSS'
              'pylsp: for Tab completing Python'
              'python-poetry: for running Poetry and Flask projects'
              'python-ruff: for formatting Python'
              'ruby: for running Ruby'
              'ruby-rubocop: for formatting Ruby'
              'rust-analyzer: for Tab completing Rust'
              'rustup: for compiling and formatting Rust'
              'scdoc: for writing man pages'
              'shfmt: for formatting Shell scripts'
              'stylua: for formatting Lua'
              'tidy: for formatting HTML and XML'
              'timidity: for playing music in the ABC notation'
              'wl-clipboard: for copy-paste on Wayland'
              'xclip: for copy-paste on X11'
              'yasm: for compiling Assembly'
              'zig: for compiling and formatting Zig'
              'zls: for Tab completing Zig')

  DESTDIR="$pkgdir" make -C $pkgbase install symlinks easteregg license
}

package_orbiton-gtk3() {
  pkgdesc='Configuration-free text editor and IDE (GTK3/VTE3)'
  depends+=(orbiton vte3)
  DESTDIR="$pkgdir" PROJECT=$pkgname make -C $pkgbase gui-install gui-symlinks license
}

package_orbiton-nano() {
  pkgdesc='Configuration-free text editor and IDE (Nano/Pico Mode)'
  depends+=(orbiton)
  conflicts=(nano)
  provides=(nano)
  install -d "$pkgdir/usr/bin"
  DESTDIR="$pkgdir" PROJECT=$pkgname make -C $pkgbase nano-symlink license
}
