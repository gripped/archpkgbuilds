pkgbase=python-cupy
pkgname=(python-cupy python-cupy-rocm-gfx9 python-cupy-rocm-gfx10 python-cupy-rocm-gfx11 python-cupy-rocm-gfx12)
pkgver=14.0.1
pkgrel=2
pkgdesc="NumPy/SciPy-compatible array library for GPU-accelerated computing with Python"
arch=(x86_64)
url="https://github.com/cupy/cupy"
license=(MIT)
makedepends=(
  git
  cython
  python-build
  python-installer
  python-wheel
  python-setuptools
  # common depends
  python-fastrlock
  python-numpy
  # CUDA build
  cuda
  # NOTE: cudnn 9 causes compilation errors and will be dropped https://github.com/cupy/cupy/issues/8215
  # TODO: package cusparselt
  cutensor
  nccl
  # ROCm build
  hip-runtime-amd
  hipblas
  hipcub
  hipfft
  hiprand
  hipsparse
  rccl
  rocfft
  rocprim
  rocrand
  rocsolver
  rocsparse
  rocthrust
  roctracer
  rocm-toolchain
)
optdepends=(
  'python-scipy: for copying sparse matrices from GPU to CPU'
  'python-optuna: for using using Automatic Kernel Parameters Optimizations (cupyx.optimizing)'
)
source=(
  "$pkgbase::git+https://github.com/cupy/cupy.git#tag=v$pkgver"
  "$pkgbase-cccl::git+https://github.com/NVIDIA/cccl.git"
  "$pkgbase-dlpack::git+https://github.com/dmlc/dlpack.git"
  "$pkgbase-jitify::git+https://github.com/NVIDIA/jitify.git"
  "$pkgbase-xsf::git+https://github.com/scipy/xsf.git"
  hipcc-include-dirs.patch
)

b2sums=('f9b2952891d8d4eebb99b45f65b2ec391841e06bb421ca92bc02b883dc52ca094a7987012bc5cfe3ec93eafde3acec48a565bfd63969cf1b47d1a19577b5a851'
        'SKIP'
        'SKIP'
        'SKIP'
        'SKIP'
        'd14e0d4b49d19d259f86ebc03a0ac4248bee1257092f14ce968c885731807c1f4bf7d0b3ac6fd745769809cd8dac4f96f9c633d63af5288623ffcddf36b99032')

# Building with over 16 arches fails in linking. Split them to separate packages.
_rocm_gfx9_targets="gfx900,gfx906:xnack-,gfx908:xnack-,gfx90a:xnack+,gfx90a:xnack-,gfx942,gfx950"
_rocm_gfx10_targets="gfx1010,gfx1012,gfx1030,gfx1031,gfx1035,gfx1036"
_rocm_gfx11_targets="gfx1100,gfx1101,gfx1102,gfx1103,gfx1150,gfx1151,gfx1152,gfx1153"
_rocm_gfx12_targets="gfx1200,gfx1201"
_rocm_depends=(
  glibc
  libgcc
  libstdc++
  hip-runtime-amd
  hipblas
  hipfft
  hiprand
  hipsparse
  rccl
  rocblas
  rocsolver
  roctracer
  python
  python-fastrlock
  python-numpy
)

prepare() {
  cd $pkgbase
  git submodule init

  git config submodule."third_party/cccl".url "$srcdir"/$pkgbase-cccl
  git config submodule."third_party/dlpack".url "$srcdir"/$pkgbase-dlpack
  git config submodule."third_party/jitify".url "$srcdir"/$pkgbase-jitify
  git config submodule."third_party/xsf".url "$srcdir"/$pkgbase-xsf

  git -c protocol.file.allow=always submodule update --init --recursive

  # release version constraints for Cython
  sed -i 's|Cython>=[0-9.]\+,<[0-9.]\+|Cython|' pyproject.toml

  # Always query hipcc for include directories in hiprtc
  # https://github.com/cupy/cupy/pull/9622
  patch -p1 < ../hipcc-include-dirs.patch

  # copy the source tree for the ROCm build
  # (most artifacts end up in the build/ directory but .cpp files get generated
  # along the other sources)
  cd "$srcdir"
  cp -ar $pkgbase $pkgbase-rocm-gfx9
  cp -ar $pkgbase $pkgbase-rocm-gfx10
  cp -ar $pkgbase $pkgbase-rocm-gfx11
  cp -ar $pkgbase $pkgbase-rocm-gfx12
}

build() {
  # CUDA build
  export CUPY_NUM_BUILD_JOBS="$(nproc)"
  export CUPY_NUM_NVCC_THREADS="$(nproc)"

  cd "$srcdir"/$pkgbase
  LDFLAGS="$LDFLAGS -L/opt/cuda/targets/x86_64-linux/lib/stubs" \
  python -m build --wheel --no-isolation

  # ROCm build
  export HIPCC_COMPILE_FLAGS_APPEND="-parallel-jobs=$(nproc)"
  export HIPCC_LINK_FLAGS_APPEND="-parallel-jobs=$(nproc)"
  export CUDA_PATH=""
  export CUPY_INSTALL_USE_HIP=1
  export ROCM_HOME=/opt/rocm
  # avoid huge amount of warnings
  HIPCC_COMPILE_FLAGS_APPEND+=" -Wno-unused-value"

  # build only gfx9
  export HCC_AMDGPU_TARGET="${_rocm_gfx9_targets}"
  echo "Building for ROCm targets: ${HCC_AMDGPU_TARGET}"
  cd "$srcdir"/$pkgbase-rocm-gfx9
  python -m build --wheel --no-isolation

  # build only gfx10
  export HCC_AMDGPU_TARGET="${_rocm_gfx10_targets}"
  echo "Building for ROCm targets: ${HCC_AMDGPU_TARGET}"
  cd "$srcdir"/$pkgbase-rocm-gfx10
  python -m build --wheel --no-isolation

  # build only gfx11
  export HCC_AMDGPU_TARGET="${_rocm_gfx11_targets}"
  echo "Building for ROCm targets: ${HCC_AMDGPU_TARGET}"
  cd "$srcdir"/$pkgbase-rocm-gfx11
  python -m build --wheel --no-isolation

  # build only gfx12
  export HCC_AMDGPU_TARGET="${_rocm_gfx12_targets}"
  echo "Building for ROCm targets: ${HCC_AMDGPU_TARGET}"
  cd "$srcdir"/$pkgbase-rocm-gfx12
  python -m build --wheel --no-isolation
}

package_python-cupy() {
  pkgdesc+=" (CUDA version)"
  depends=(
    cuda
    glibc
    libgcc
    libstdc++
    python
    python-fastrlock
    python-numpy
  )
  optdepends+=(
    'cutensor: for acceleratedd tensor operations'
    'nccl: for collective multi-GPU computations'
  )

  cd $pkgbase
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -vDm 644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

package_python-cupy-rocm-gfx9() {
  pkgdesc+=" (ROCm gfx9 targets)"
  depends=(${_rocm_depends[@]})
  conflicts=(python-cupy)
  provides=(python-cupy)

  cd $pkgbase-rocm-gfx9
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -vDm 644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

package_python-cupy-rocm-gfx10() {
  pkgdesc+=" (ROCm gfx10 targets)"
  depends=(${_rocm_depends[@]})
  conflicts=(python-cupy)
  provides=(python-cupy)

  cd $pkgbase-rocm-gfx10
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -vDm 644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

package_python-cupy-rocm-gfx11() {
  pkgdesc+=" (ROCm gfx11 targets)"
  depends=(${_rocm_depends[@]})
  conflicts=(python-cupy)
  provides=(python-cupy)
  replaces=(python-cupy-rocm)

  cd $pkgbase-rocm-gfx11
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -vDm 644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}

package_python-cupy-rocm-gfx12() {
  pkgdesc+=" (ROCm gfx12 targets)"
  depends=(${_rocm_depends[@]})
  conflicts=(python-cupy)
  provides=(python-cupy)

  cd $pkgbase-rocm-gfx12
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -vDm 644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}
