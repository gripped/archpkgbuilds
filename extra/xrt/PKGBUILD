# Maintainer: Torsten Keßler <tpkessler at archlinux dot org>
# Contributor: Lubosz Sarnecki <lubosz@gmail.com>
pkgname=xrt
pkgver=2.21.75
pkgrel=2
epoch=1
pkgdesc='Runtime for AIE and FPGA based platforms '
arch=('x86_64')
url='https://xilinx.github.io/XRT/'
license=('Apache-2.0 AND GPL-2.0-only')
depends=(
  'glibc'
  'gcc-libs'
  'libdrm'
  'protobuf'
  'abseil-cpp'
  'boost-libs'
)
makedepends=(
  'git'
  'cmake'
  'ninja'
  # We need some OpenCL library for CMake
  'rocm-opencl-runtime'
  'opencl-headers'
  'opencl-clhpp'
  'boost'
  'rapidjson'
  'python'
  'pybind11'
)
optdepends=(
  'python: Python bindings'
)

options=(!lto)
source=(
  "${pkgname}::git+https://github.com/Xilinx/XRT#tag=${pkgver}"
  "${pkgname}-ELFIO::git+https://github.com/serge1/ELFIO.git"
  "${pkgname}-GSL::git+https://github.com/microsoft/GSL.git"
  "${pkgname}-aiebu::git+https://github.com/Xilinx/aiebu.git"
  "${pkgname}-dma_ip_drivers::git+https://github.com/Xilinx/dma_ip_drivers.git"
  "install-to-bin.patch"
  "protobuf-abseil.patch"
)
sha256sums=('861a24ad46a215c6a015c8652c1473aa00dd6b3e7c881b60c5d64ff70ead1d19'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            '68bf7e99af055e942882459c70b62d5aca451b4034ad86d126d98b264c7018d6'
            '0820a86fe1e9f1d66cc2cdbaeed77baf76cf9180c6aa619b54584fc03849ed80')

prepare() {
  cd "${srcdir}/${pkgname}"
  git submodule init

  git config submodule."src/runtime_src/core/common/aiebu".url "${srcdir}/${pkgname}"-aiebu
  git config submodule."src/runtime_src/core/common/elf".url "${srcdir}/${pkgname}"-ELFIO
  git config submodule."src/runtime_src/core/common/gsl".url "${srcdir}/${pkgname}"-GSL
  git config submodule."src/runtime_src/core/pcie/driver/linux/xocl/lib/libqdma".url "${srcdir}/${pkgname}"-dma_ip_drivers

  git -c protocol.file.allow=always submodule update --init --recursive

  git -C src/runtime_src/core/common/aiebu/ checkout 4bf58d5a8d46089847130ecffb8952504482feb5

  # Cmake can't find protobuf's abseil dependency, see for instance
  # https://github.com/protocolbuffers/protobuf/issues/12292#issuecomment-1529680040
  # One solution is to use pkg-config to get a list of all abseil libs,
  # https://github.com/protocolbuffers/protobuf/issues/12637#issuecomment-1871458639
  patch -Np1 -i ../protobuf-abseil.patch
  patch -Np1 -i ../install-to-bin.patch
}

build() {
  local cmake_args=(
    -Wno-dev
    -S xrt
    -B build
    -G Ninja
    -D CMAKE_BUILD_TYPE=None
    -D CMAKE_INSTALL_PREFIX=/usr
    -D XRT_ENABLE_WERROR=OFF
  )
  cmake "${cmake_args[@]}"
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build

  install -Dm644 "$pkgname/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  rm -f "$pkgdir/usr/include/CL/cl_ext.h"
}
