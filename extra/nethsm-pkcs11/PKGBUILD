# Maintainer: David Runge <dvzrv@archlinux.org>

pkgname=nethsm-pkcs11
pkgver=2.1.0
pkgrel=1
pkgdesc="PKCS#11 driver for NetHSM"
arch=(x86_64)
url="https://github.com/Nitrokey/nethsm-pkcs11"
license=(Apache-2.0)
depends=(glibc)
makedepends=(rust)
options=(!lto)  # NOTE: as ring is used we can not use LTO
source=(
  $pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz
)
sha512sums=('1d1b2cfbabf4f3b6cf0396802429f8ee0fa46224073e9fbfc80339c0e45392d2435dee86c2f9ac9c09b15bbb7bdc1012f5e1af0404f06680aca64c904d78278e')
b2sums=('aca60b70a31b5a263b222c99a48ec1baea74f368664c66f674abafb6daef20b372bd7e419b40aafe5bfbacba57ca31f7aedaeabad2b48e51953fac48f4bece9b')

prepare() {
  cd $pkgname-$pkgver
  cargo fetch --locked --target "$(rustc --print host-tuple)"
}

build() {
  cd $pkgname-$pkgver
  cargo build --frozen --release --all-features
}

check() {
  cd $pkgname-$pkgver
  # using all features pulls in pkcs11-full-tests which are integration tests
  cargo test --frozen --features=default
}

package() {
  cd $pkgname-$pkgver
  install -vDm 755 target/release/lib${pkgname/-/_}.so -t "$pkgdir/usr/lib/"
  install -vDm 644 {{README,features}.md,p11nethsm*.conf} -t "$pkgdir/usr/share/doc/$pkgname/"
  install -vdm 700 "$pkgdir/etc/nitrokey/"
}
