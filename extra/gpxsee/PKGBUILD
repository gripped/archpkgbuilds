pkgname=gpxsee
_pkgname=GPXSee
pkgver=16.0
pkgrel=1
pkgdesc='GPS log file viewer and analyzer'
arch=(x86_64)
url='https://www.gpxsee.org/'
license=(GPL-3.0-only)
depends=('qt6-imageformats' 'qt6-positioning' 'qt6-svg'
         'qt6-serialport' 'qt6-multimedia' 'hicolor-icon-theme')
makedepends=('qt6-tools')
source=(https://downloads.sourceforge.net/$pkgname/$_pkgname-$pkgver.tar.gz)
sha256sums=('c6210377103171a6e163b71eeb3e49a4659f326c1b7afdd311197444de39d1ce')

build() {
  cd $_pkgname-$pkgver
  /usr/lib/qt6/bin/lrelease gpxsee.pro
  qmake6 gpxsee.pro PREFIX=/usr
  make
}

package() {
  cd $_pkgname-$pkgver
  make INSTALL_ROOT="$pkgdir" install
}
