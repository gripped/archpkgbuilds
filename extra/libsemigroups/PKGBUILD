# Maintainer: Antonio Rojas <arojas@archlinux.org>

pkgname=libsemigroups
pkgver=3.5.1
pkgrel=1
pkgdesc='C++ library for semigroups and monoids'
url='https://libsemigroups.github.io'
arch=(x86_64)
license=(GPL-3.0-or-later)
depends=(fmt
         glibc
         libgcc
         libstdc++)
makedepends=(eigen
             git)
source=(git+https://github.com/libsemigroups/libsemigroups#tag=v$pkgver)
sha256sums=('1fa665a632adb06ac966678c2bdf6eea19813f3b07139de45efb3106602ff96c')

prepare() {
  cd $pkgname
  autoreconf -vif
}

build() {
  cd $pkgname
  ./configure --prefix=/usr \
              --disable-hpcombi \
              --enable-fmt \
              --with-external-fmt \
              --with-external-eigen
  make
}

package() {
  cd $pkgname
  make DESTDIR="$pkgdir" install
}
