# Maintainer: George Rawlinson <grawlinson@archlinux.org>

pkgname=openfpgaloader
pkgver=1.1.0
pkgrel=1
pkgdesc='Universal utility for programming FPGA'
arch=(x86_64)
url='https://github.com/trabucayre/openFPGALoader'
license=(Apache-2.0)
depends=(
  libftdi
  libftdi-compat
  libhidapi-hidraw.so
  libhidapi-libusb.so
  libudev.so
  libusb
  zlib
  glibc
  libgcc
  libstdc++
)
makedepends=(
  git
  cmake
  systemd
)
source=("$pkgname::git+$url#tag=v$pkgver")
sha512sums=('4f9ce75f58aabfad29b76a3dae6881cc4680b971f314fa2d03b23fd6684875976b813ad37bf9a2775be81990e558d5612b232446175d060708f49e99bb9026fc')
b2sums=('b4a85de328ef10f81fb41ba7d8e19a8fa28f72e1901408d084c7158b6dc1c6c836bb039e5164378d3e6c6c0538ffe5df8e2f0050c5187610fb08d6ced80a9bcf')

prepare() {
  cd "$pkgname"

  sed -i 's|MODE="664", GROUP="plugdev"|MODE="666"|g' 99-openfpgaloader.rules
}

build() {
  local cmake_options=(
    -B build
    -S "$pkgname"
    -W no-dev
    -D CMAKE_BUILD_TYPE=None
    -D CMAKE_INSTALL_PREFIX=/usr
    -D ENABLE_UDEV=ON
    -D ENABLE_CMSISDAP=ON
  )

  cmake "${cmake_options[@]}"

  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build

  install -vDm644 -t "$pkgdir/usr/lib/udev/rules.d" "$pkgname/99-openfpgaloader.rules"
}

