# Maintainer: Guillaume ALAUX <guillaume@archlinux.org>

pkgname=hyphen-fr
pkgver=3.0
pkgrel=6
_commit=3fc3d99f071693dd40a78ba1f729ef47dc189692
_name=dictionaries
pkgdesc="French hyphenation rules"
arch=('any')
url='https://wiki.documentfoundation.org/Development/Dictionaries'
license=('LGPL-2.1-or-later')
makedepends=(git)
optdepends=('hyphen: offers hyphenation library functions')
source=(git+https://anongit.freedesktop.org/git/libreoffice/dictionaries.git#commit=$_commit)
sha512sums=('f0c7e683e1bab427392463984d830ca8aab07dcf691ec1a6a0e5d7e4433b72a39bc2579d8fdc7db50a7983d19eaa64e674d7c55168168677cc81e677f5ec5586')
b2sums=('5c1ce18e1e3e881dd1142836b8239c723ae1e309b02daeffcae373cbca8034ba54a4b3a247bd21acad1ee14ae610a7ceb19e83bd1e1ff16b9f8bfcb1f43db237')

package() {
  local aliases=(fr_BE fr_CA fr_CH fr_LU)
  local lang file

  install -vDm 644 $_name/fr_FR/hyph_fr.dic "$pkgdir/usr/share/hyphen/hyph_fr_FR.dic"
  install -vdm 755 "$pkgdir/usr/share/myspell/dicts/"

  for lang in "${aliases[@]}"; do
    ln -sv hyph_fr_FR.dic "${pkgdir}/usr/share/hyphen/hyph_$lang.dic"
  done

  for file in "$pkgdir/usr/share/hyphen/"*; do
    ln -sv "/usr/share/hyphen/$(basename $file)" "$pkgdir/usr/share/myspell/dicts/$(basename $file)"
  done

  install -vDm 644 $_name/fr_FR/README*.txt -t "$pkgdir/usr/share/doc/$pkgname/"
}
