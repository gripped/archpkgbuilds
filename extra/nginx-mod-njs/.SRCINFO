pkgbase = nginx-mod-njs
	pkgdesc = nginScript module for nginx
	pkgver = 0.9.6
	pkgrel = 1
	url = https://nginx.org/en/docs/njs_about.html
	arch = x86_64
	license = BSD-2-Clause
	makedepends = nginx
	makedepends = nginx-src
	depends = glibc
	depends = libxslt
	depends = openssl
	depends = zlib
	depends = pcre2
	depends = libxml2
	source = https://github.com/nginx/njs/archive/refs/tags/0.9.6/nginx-mod-njs-0.9.6.tar.gz
	sha256sums = 713e931d1ffcd337f6304dc55e512dcf2099ba4cc3a996c9ea14f22d5d9cdd79

pkgname = nginx-mod-njs
	depends = glibc
	depends = libxslt
	depends = openssl
	depends = zlib
	depends = pcre2
	depends = libxml2
	depends = nginx
	backup = etc/nginx/modules.d/20-njs-http.conf

pkgname = nginx-mod-njs-stream
	pkgdesc = nginScript module for nginx streams
	depends = glibc
	depends = libxslt
	depends = openssl
	depends = zlib
	depends = pcre2
	depends = libxml2
	depends = nginx
	depends = nginx-mod-stream
	backup = etc/nginx/modules.d/20-njs-stream.conf
