# Maintainer: Jakub Klinkovský <lahwaacz at archlinux dot org>

_name=metakernel
pkgname=jupyter-$_name
pkgver=0.32.0
pkgrel=1
pkgdesc="A Jupyter/IPython kernel template"
arch=(any)
url="https://github.com/Calysto/metakernel"
license=(BSD-3-Clause)
depends=(
  python
  python-ipykernel
  python-jedi
  python-jupyter-core
  python-pexpect
  # implicitly satisfied
  ipython
  python-jupyter-client
  python-parso
  python-pyzmq
  python-traitlets
)
makedepends=(
  python-build
  python-hatchling
  python-installer
)
checkdepends=(
  python-pytest
  python-pytest-timeout
  python-requests
  man-db
)
optdepends=(
  'python-ipywidgets: for activity magics'
  'python-ipyparallel: for parallel magics'
  'python-matplotlib: for matplotlib magics'
  'python-pydot: for dot magics'
)
source=($pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz
        pyproject.patch)
b2sums=('067ee111824911ff4df6333655cb072354178ce1271c6e6904a1909d3d029846fbcd574e29459ccc19d64a267342c06ba4b41803c9c39d793e5a59b77bd8c914'
        '7080f3016d0091fb25379955d481ba0dc11a6dfaa01056926ea670efdb5fe58c8c86845c59aa01e84b100a30cbfbbdcca548f46eb7eeab95324ff5c8d47916b5')

prepare() {
  cd $_name-$pkgver
  # Drop strict pytest minversion requirement
  patch -p1 < ../pyproject.patch
}

build() {
  cd $_name-$pkgver
  python -m build --wheel --no-isolation
}

check() {
  local pytest_options=(
    -vv
    -W ignore::DeprecationWarning
    --override-ini="addopts="
    # AssertionError: assert 'bashrc' in []
    --deselect tests/test_parser.py::test_path_completions
    # ValueError: Stdin Requested but not stdin handler available
    --deselect tests/test_replwrap.py::REPLWrapTestCase::test_python
  )

  cd $_name-$pkgver
  python -m venv --system-site-packages test-env
  test-env/bin/python -m installer dist/*.whl
  test-env/bin/python -m pytest "${pytest_options[@]}" tests
}

package() {
  cd $_name-$pkgver
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -vDm 644 LICENSE.txt -t "$pkgdir"/usr/share/licenses/$pkgname/
}
