pkgname=glacier-calc
pkgver=0.3.4
pkgrel=1
pkgdesc="Nemo calculator"
arch=('x86_64')
url="https://github.com/nemomobile-ux/glacier-calc"
license=('LGPL-2.1-only')
depends=('qt5-quickcontrols-nemo')
makedepends=('git' 'cmake' 'qt5-tools')
source=("git+https://github.com/nemomobile-ux/glacier-calc.git#tag=$pkgver")
sha512sums=('1590bb75cbf08370093f1cbf6c7dded5bda516c84887ee68bda7f0ab58e7e33de05fe9fcbe44aba7348b79a092aca200fe09eab8afcc779a8af304552f3b1811')

build(){
  cd glacier-calc

  cmake -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_POLICY_VERSION_MINIMUM=3.5 .
  make
}

package() {
  cd glacier-calc
  make DESTDIR="$pkgdir" install
}
