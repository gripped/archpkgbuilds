pkgname=abcmidi
pkgver=2026_02_24
pkgrel=1
pkgdesc='Tools for ABC and MIDI files'
groups=(pro-audio)
arch=(x86_64)
url='https://github.com/sshlien/abcmidi'
license=(GPL-2.0-or-later)
makedepends=(git)
depends=(glibc)
source=("git+$url#tag=${pkgver//_/.}")
b2sums=('23c9f35e9b8723f2d69a7ad1f8761bb3833696d20e5c1adcfd62942eeee42244e8c9364305c54b259d565daefc1623bab68a0bdd4a7692f1311dd95c2fb25499')

build() {
  cd $pkgname
  export CFLAGS+=' -std=c99 -Wno-implicit-function-declaration'
  ./configure --prefix=/usr
  make
}

package() {
  cd $pkgname
  make DESTDIR="$pkgdir" install
  install -m 755 -d "$pkgdir"/usr/share/doc/$pkgname/{programming,samples}
  install -m 644 -t "$pkgdir"/usr/share/doc/$pkgname/programming doc/programming/*.{abc,txt}
  install -m 644 -t "$pkgdir"/usr/share/doc/$pkgname/samples samples/*.abc
}
