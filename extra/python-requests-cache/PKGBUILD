pkgname=python-requests-cache
pkgver=1.3.1
pkgrel=1
pkgdesc='Persistent HTTP cache for python requests'
arch=(any)
url='https://github.com/requests-cache/requests-cache'
license=(BSD-2-Clause)
depends=(
  python
  python-requests
  python-urllib3
  python-attrs
  python-cattrs
  python-platformdirs
  python-url-normalize
)
makedepends=(
  git
  python-build
  python-installer
  python-hatchling
)
checkdepends=(
  python-pytest
  python-requests-mock
  python-rich
  python-pymongo
  python-responses
  python-redis
  python-tenacity
)
optdepends=(
  'python-boto3: DynamoDB support'
  'python-botocore: DynamoDB support'
  'python-pymongo: MongoDB support'
  'python-redis: Redis support'
)
source=("$pkgname::git+$url#tag=v$pkgver")
sha512sums=('fc8cf66e359383cda787e6535ccb0c95610e04d3419db128b211e147e89103b7494bf32031746158cab151a4630043fdae8201494cec158d0e7dfd531e6ce8d0')
b2sums=('1840430f5a8fc295595d6bd2865dff914d62b8e41c70abfd473ba215c1c6ec973a145ea811944d4df3589dc4289a9f8d33def2dd179fca6092fdcd9126cad772')

build() {
  cd "$pkgname"

  python -m build --wheel --no-isolation
}

#check() {
#  cd "$pkgname"
#
#  pytest -v
#}

package() {
  cd "$pkgname"

  python -m installer --destdir="$pkgdir" dist/*.whl

  # license
  install -vDm644 -t "$pkgdir/usr/share/licenses/$pkgname" LICENSE
}
