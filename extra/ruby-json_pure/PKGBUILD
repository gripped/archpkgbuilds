# Maintainer: Felix Yan <felixonmars@archlinux.org>

pkgname=ruby-json_pure
pkgver=2.7.0
pkgrel=1
pkgdesc='A JSON implementation in pure Ruby'
arch=(any)
url='https://flori.github.io/json/'
license=(RUBY)
depends=(
  ruby
  ruby-bigdecimal
)
makedepends=(
  git
  ruby-rake
  ruby-rdoc
)
checkdepends=(
  ruby-test-unit
  ruby-test-unit-ruby-core
)
options=(!emptydirs)
source=(git+https://github.com/flori/json.git#tag=v$pkgver)
sha256sums=('0fd77975caac2b044fd5b3d1f1f09bbd3fbb3d6d0ceaecc25b7ef58737bf3151')

build() {
  local _gemdir="$(gem env gemdir)"
  cd json
  gem build json_pure.gemspec
  gem install \
    --local \
    --verbose \
    --ignore-dependencies \
    --no-user-install \
    --install-dir "tmp_install/$_gemdir" \
    --bindir "tmp_install/usr/bin" \
    json_pure-$pkgver.gem
  find "tmp_install/$_gemdir/gems/" \
    -type f \
    \( \
        -iname "*.o" -o \
        -iname "*.c" -o \
        -iname "*.so" -o \
        -iname "*.time" -o \
        -iname "gem.build_complete" -o \
        -iname "Makefile" \
    \) \
    -delete
  rm -r tmp_install/$_gemdir/cache
}

check() {
  local _gemdir="$(gem env gemdir)"
  cd json
  GEM_HOME="tmp_install/$_gemdir" rake test_pure
}

package() {
  cd json
  cp -a tmp_install/* "$pkgdir"/
}
