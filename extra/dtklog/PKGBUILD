# Maintainer: Felix Yan <felixonmars@archlinux.org>

pkgbase=dtklog
pkgname=(dtklog dtk6log)
pkgver=6.7.31
pkgrel=1
pkgdesc='Simple, convenient and thread safe logger for Qt-based C++ apps'
arch=('x86_64')
url="https://github.com/linuxdeepin/dtklog"
license=('LGPL-3.0-or-later')
groups=('deepin')
makedepends=('git' 'cmake' 'ninja' 'qt5-base' 'qt6-base' 'spdlog' 'fmt')
source=("git+https://github.com/linuxdeepin/dtklog.git#tag=$pkgver")
sha512sums=('74eace82c414431e60142cdd26a3fbb5d80159ca37d58f542b17bbb81939834adf6ea3f6c96ef1004386e55f4c683b9e25fd6324d5a58f5993d274f3dc544deb')

build() {
  cd dtklog

  # Build Qt5 variant (dtklog)
  cmake . -Bbuild-qt5 -GNinja \
    -DDTK5=ON \
    -DBUILD_WITH_SYSTEMD=ON \
    -DMKSPECS_INSTALL_DIR=lib/qt/mkspecs/modules \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build-qt5

  # Build Qt6 variant (dtk6log)
  cmake . -Bbuild-qt6 -GNinja \
    -DDTK5=OFF \
    -DBUILD_WITH_SYSTEMD=ON \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build-qt6
}

package_dtklog() {
  pkgdesc='Simple, convenient and thread safe logger for Qt-based C++ apps (Qt5 build)'
  depends=('glibc' 'libgcc' 'libstdc++' 'libsystemd' 'qt5-base' 'spdlog' 'fmt')

  cd dtklog
  DESTDIR="$pkgdir" ninja -C build-qt5 install
}

package_dtk6log() {
  pkgdesc='Simple, convenient and thread safe logger for Qt-based C++ apps (Qt6 build)'
  depends=('glibc' 'libgcc' 'libstdc++' 'libsystemd' 'qt6-base' 'spdlog' 'fmt')

  cd dtklog
  DESTDIR="$pkgdir" ninja -C build-qt6 install
}
