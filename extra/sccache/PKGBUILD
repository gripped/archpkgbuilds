# Maintainer: Maxime Gauduin <alucryd@archlinux.org>
# Contributor: Chocobo1 <chocobo1@archlinux.net>
# Contributor: Jean Lucas <jean@4ray.co>

pkgname=sccache
pkgver=0.14.0
pkgrel=1
pkgdesc='Shared compilation cache'
arch=(x86_64)
url=https://github.com/mozilla/sccache
license=(Apache-2.0)
depends=(
  gcc-libs
  glibc
  openssl
)
makedepends=(
  git
  rust
)
optdepends=(
  'memcached: Memcached support'
  'valkey: Redis support'
)
options=(!lto)
_tag=6ea77c318e4a50fb713a7b1e7a09a87a0b7e114c
source=(git+https://github.com/mozilla/sccache.git#tag=${_tag})
b2sums=('1fa952bb5bc48ead12c1ade9a83473384c72336495b51db5d912daadcc09d2d5895b63e47bb08b6200f67c58b2f199f68bee13d4b2657ce0b612c016d6ab6855')

prepare() {
  cd sccache
  cargo fetch --locked
}

pkgver() {
  cd sccache
  git describe --tags | sed 's/^v//'
}

build() {
  cd sccache

  # Use debug
  export CARGO_PROFILE_RELEASE_DEBUG=2 CARGO_PROFILE_RELEASE_STRIP=false

  # Use LTO
  export CARGO_PROFILE_RELEASE_LTO=true CARGO_PROFILE_RELEASE_CODEGEN_UNITS=1

  cargo build --release --frozen --features all,dist-server
}

#check() {
#  cd sccache
#  cargo test --frozen --features all,dist-server
#}

package() {
  cd sccache
  install -Dt "$pkgdir/usr/bin" target/release/sccache{,-dist}
  install -Dt "$pkgdir/usr/share/doc/$pkgname" -m644 README.md docs/*
}

# vim:set sw=2 sts=-1 et:
