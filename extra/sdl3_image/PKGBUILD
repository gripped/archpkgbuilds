# Maintainer: Martin Rys <https://rys.rs/contact>
# Contributor: Erik Kallen <info@erikkallen.nl>

pkgname=sdl3_image
pkgver=3.4.0
pkgrel=1
pkgdesc="SDL3 image loading library"
arch=("x86_64")
url="https://github.com/libsdl-org/SDL_image"
license=("Zlib")
depends=(
	"sdl3"
	"libpng"
	"libtiff"
	"libjpeg"
	"libwebp"
	"libavif"
	"libjxl"
)
makedepends=("cmake")
source=("https://github.com/libsdl-org/SDL_image/releases/download/release-${pkgver}/SDL3_image-${pkgver}.tar.gz")
sha256sums=('2ceb75eab4235c2c7e93dafc3ef3268ad368ca5de40892bf8cffdd510f29d9d8')

build() {
	cmake \
		-B build \
		-S "SDL3_image-${pkgver}" \
		-DSDLIMAGE_SAMPLES=OFF \
		-DSDLIMAGE_TESTS=OFF \
		-DCMAKE_BUILD_TYPE=None \
		-DCMAKE_INSTALL_PREFIX=/usr

	cmake --build build
}

package() {
	DESTDIR="${pkgdir}" cmake --install build
	install -Dm644 "SDL3_image-${pkgver}/LICENSE.txt" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
