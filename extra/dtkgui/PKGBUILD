# Maintainer: Felix Yan <felixonmars@archlinux.org>

pkgbase=dtkgui
pkgname=(dtkgui dtk6gui)
pkgver=6.7.31
pkgrel=1
epoch=1
pkgdesc='Deepin Toolkit, gui module for DDE look and feel'
arch=('x86_64')
url="https://github.com/linuxdeepin/dtkgui"
license=('LGPL-3.0-or-later')
groups=('deepin')
makedepends=('git' 'cmake' 'ninja' 'extra-cmake-modules' 'qt5-tools' 'qt6-tools' 'gtest' 'doxygen'
             'dtkcore' 'dtk6core' 'libqt5xdg' 'librsvg' 'qt5-base' 'qt6-base' 'qt5-wayland'
             'glib2' 'libx11' 'treeland-protocols')
source=("git+https://github.com/linuxdeepin/dtkgui.git#tag=$pkgver"
        "fix-dtk5-include-path.patch")
sha512sums=('0c75c103cc1800975f75dc811fae64a43375ddff835968566555711dc41d5954533a96e0b150b74cc8fa0875752d687fa044a04d0ce231bb35a3336a4a08f824'
            '8034b3a4d7298f561df7178d887c92f645d50fb37f76939c5f983f5d4a0e80ffa1ae0a58c41bb5084db8718dbbd8ae4af578440bd18fe4bb4719ccbdb729bac8')

prepare() {
  cd dtkgui
  # Fix upstream bug: PROJECT_VERSION_MAJOR should be DTK_VERSION_MAJOR
  # This ensures private headers install to correct path (dtk5 vs dtk6)
  # https://github.com/linuxdeepin/dtkgui/pull/368
  patch -p1 -i "$srcdir/fix-dtk5-include-path.patch"

  cd ..
  # Use separate source directories for Qt5 and Qt6 builds
  # The upstream CMake writes generated files (dtkgui_config.h, DtkGuis) directly
  # in the source directory, which causes conflicts when building both variants
  mkdir -p build-qt5 build-qt6
  cp -r dtkgui build-qt5/dtkgui
  cp -r dtkgui build-qt6/dtkgui
}

build() {
  # Build Qt5 variant (dtkgui)
  cd build-qt5/dtkgui
  cmake . -Bbuild -GNinja \
    -DDTK5=ON \
    -DBUILD_DOCS=ON \
    -DBUILD_TESTING=ON \
    -DDTK_DISABLE_EX_IMAGE_FORMAT=ON \
    -DMKSPECS_INSTALL_DIR=lib/qt/mkspecs/modules \
    -DQCH_INSTALL_DESTINATION=share/doc/qt \
    -DCMAKE_INSTALL_LIBEXECDIR=lib \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build

  cd "$srcdir"
  # Build Qt6 variant (dtk6gui)
  cd build-qt6/dtkgui
  cmake . -Bbuild -GNinja \
    -DDTK5=OFF \
    -DBUILD_DOCS=ON \
    -DBUILD_TESTING=ON \
    -DDTK_DISABLE_EX_IMAGE_FORMAT=ON \
    -DCMAKE_INSTALL_LIBEXECDIR=lib \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build
}

check() {
  cd build-qt5/dtkgui
  ninja -C build test || echo "Qt5 tests failed"

  cd "$srcdir/build-qt6/dtkgui"
  ninja -C build test || echo "Qt6 tests failed"
}

package_dtkgui() {
  pkgdesc='Deepin Toolkit, gui module for DDE look and feel (Qt5 build)'
  depends=('dtkcore' 'glib2' 'glibc' 'libgcc' 'libgomp' 'libqt5xdg' 'librsvg' 'libstdc++' 'libx11'
           'qt5-base' 'qt5-wayland')

  cd build-qt5/dtkgui
  DESTDIR="$pkgdir" ninja -C build install
}

package_dtk6gui() {
  pkgdesc='Deepin Toolkit, gui module for DDE look and feel (Qt6 build)'
  depends=('dtk6core' 'glib2' 'glibc' 'libgcc' 'libgomp' 'librsvg' 'libstdc++' 'libx11'
           'qt6-base' 'wayland')

  cd build-qt6/dtkgui
  DESTDIR="$pkgdir" ninja -C build install
}
