pkgname=systemc
pkgver=3.0.1
pkgrel=1
pkgdesc="Set of C++ classes and macros which provide an event-driven simulation interface for modeling and describing complex hardware systems"
url="http://www.accellera.org/downloads/standards/systemc"
arch=('x86_64')
license=('Apache')
depends=('gcc-libs')
makedepends=('cmake' 'ninja' 'git')
replaces=('systemc-cmake')
source=("git+https://github.com/accellera-official/systemc.git#tag=$pkgver")
sha512sums=('463e57295eaea929d02b62f3269ab665d5720f4d5dc85ee820d8464b684acaa741e5d83e5caeee15cd9f14282f540238af3227a4762d53fd03d2f0bc1c8665fa')

prepare() {
  mkdir -p build
  cd systemc
  # Don't force CMAKE_BUILD_TYPE to Release (Arch uses noconfig)
  sed -i '/if(NOT CMAKE_BUILD_TYPE/,/^endif()/d' CMakeLists.txt
  # Fix ctest to handle empty CMAKE_BUILD_TYPE (Arch uses noconfig)
  sed -i 's/-C "\$<CONFIG>"//' cmake/SystemCTesting.cmake
}

build() {
  cd build
  cmake -GNinja -DCMAKE_CXX_STANDARD=17 -DCMAKE_INSTALL_PREFIX=/usr ../systemc
  ninja
}

check() {
  cd build
  ninja check
}

package() {
  cd build
  DESTDIR="$pkgdir" ninja install
}
