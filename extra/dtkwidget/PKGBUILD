# Contributor: Xu Fasheng <fasheng.xu[AT]gmail.com>

pkgbase=dtkwidget
pkgname=(dtkwidget dtk6widget)
pkgver=6.7.32
pkgrel=1
epoch=1
pkgdesc='Deepin base graphical widgets library'
arch=('x86_64')
url="https://github.com/linuxdeepin/dtkwidget"
license=('LGPL-3.0-or-later')
groups=('deepin')
# qt5-imageformats/qt6-imageformats is needed for webp (dci) icons
makedepends=('git' 'cmake' 'ninja' 'qt5-tools' 'qt6-tools' 'gtest' 'doxygen'
             'dtkcore' 'dtkgui' 'dtk6core' 'dtk6gui' 'gsettings-qt'
             'qt5-base' 'qt5-imageformats' 'qt5-svg' 'qt5-x11extras'
             'qt6-base' 'qt6-imageformats' 'qt6-svg'
             'libx11' 'libxcb' 'libxext' 'libxi' 'startup-notification' 'xcb-util')
source=("git+https://github.com/linuxdeepin/dtkwidget.git#tag=$pkgver"
        "qt-6.10.2.patch")
sha512sums=('63d6351ec34617b1c4ed461670901ba6a22888708a0537a4f321a0380fa9984e4fd91927a0d618ebf33053452f4bc209dd72cd29bb2749cc426c76061b441348'
            '4aa82c9883032ec9bd00942576f2985a4d68bec9b58c1d2b1f617bcc0f98f8cb325c266cd7002cf587e137f9ee997ae94220263f7388e601e5face8ca27e2533')

prepare() {
  cd dtkwidget
  git cherry-pick -n c2d2dd15d7747ec89d8621a613e7212a11119d59
  patch -p1 -i "$srcdir/qt-6.10.2.patch"
}

build() {
  cd dtkwidget

  # Build Qt5 variant (dtkwidget)
  cmake . -Bbuild-qt5 -GNinja \
    -DDTK5=ON \
    -DBUILD_DOCS=ON \
    -DBUILD_PLUGINS=OFF \
    -DBUILD_TESTING=ON \
    -DMKSPECS_INSTALL_DIR=lib/qt/mkspecs/modules \
    -DQCH_INSTALL_DESTINATION=share/doc/qt \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_INSTALL_LIBEXECDIR=lib \
    -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build-qt5

  # Build Qt6 variant (dtk6widget)
  cmake . -Bbuild-qt6 -GNinja \
    -DDTK5=OFF \
    -DBUILD_DOCS=ON \
    -DBUILD_PLUGINS=OFF \
    -DBUILD_TESTING=ON \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_INSTALL_LIBEXECDIR=lib \
    -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build-qt6
}

check() {
  cd dtkwidget
  ninja -C build-qt5 test || echo "Qt5 tests failed"
  ninja -C build-qt6 test || echo "Qt6 tests failed"
}

package_dtkwidget() {
  pkgdesc='Deepin base graphical widgets library (Qt5 build)'
  depends=('dtkcore' 'dtkgui' 'glibc' 'libgcc' 'libstdc++' 'gsettings-qt' 'libx11' 'libxcb' 'libxext' 'libxi'
           'qt5-base' 'qt5-imageformats' 'qt5-svg' 'qt5-x11extras' 'startup-notification' 'xcb-util')
  replaces=('deepin-tool-kit')

  cd dtkwidget
  DESTDIR="$pkgdir" ninja -C build-qt5 install
}

package_dtk6widget() {
  pkgdesc='Deepin base graphical widgets library (Qt6 build)'
  depends=('dtk6core' 'dtk6gui' 'glibc' 'libgcc' 'libstdc++' 'libx11' 'libxcb' 'libxext' 'libxi'
           'qt6-base' 'qt6-imageformats' 'qt6-svg' 'startup-notification' 'xcb-util')

  cd dtkwidget
  DESTDIR="$pkgdir" ninja -C build-qt6 install
}
