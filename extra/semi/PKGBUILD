pkgname=semi
pkgver=1.14.6
_commit=5edbb0d925845a5c59abc03003569178a13d862f
pkgrel=11
pkgdesc="A library to provide MIME feature for GNU Emacs."
arch=(any)
url="https://github.com/wanderlust/semi"
license=('GPL')
depends=('emacs' 'emacs-apel>=10.7' 'flim>=1.6.0')
makedepends=('git')
source=("git+https://github.com/wanderlust/semi#commit=${_commit}")
sha256sums=('SKIP')

build() {
  cd "$srcdir"/semi
  mkdir -p ${HOME}/.emacs.d/elpa
  make
}

package() {
  cd "$srcdir"/semi
  make install PREFIX="$pkgdir"/usr
}
