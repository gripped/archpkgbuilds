# Maintainer: Jakub Klinkovský <lahwaacz@archlinux.org>

_name=nsight
pkgname=python-$_name
pkgver=0.9.6
pkgrel=1
pkgdesc="Python kernel profiling interface based on NVIDIA Nsight Tools"
arch=(any)
url="https://docs.nvidia.com/nsight-python/index.html"
license=(Apache-2.0)
depends=(
  nsight-compute  # ncu binary and ncu_report Python module
  python
  python-cuda-core
  python-deepdiff
  python-matplotlib
  python-numpy
  python-nvidia-ml-py
  python-nvtx
  python-pandas
)
makedepends=(
  python-build
  python-hatchling
  python-hatch-vcs
  python-installer
  python-wheel
)
source=(
  $pkgname-$pkgver.tar.gz::https://github.com/NVIDIA/nsight-python/archive/refs/tags/v$pkgver.tar.gz
)
b2sums=('aa7fdee94b22a066606a1b8581b16b7f54c7d252483ecc2fc4e51510da62c8aaea3532173a9a530b9882cd23b9bdc977a12edc0658fdd7befa3665158aff87d8')

build() {
  cd $_name-python-$pkgver
  SETUPTOOLS_SCM_PRETEND_VERSION=$pkgver \
  python -m build --wheel --no-isolation
}

package() {
  cd $_name-python-$pkgver
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -vDm 644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}
