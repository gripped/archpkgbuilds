# Maintainer: David Runge <dvzrv@archlinux.org>

pkgname=mbuffer
pkgver=20260221
pkgrel=1
pkgdesc="A tool for buffering data streams"
arch=(x86_64)
url="https://www.maier-komor.de/mbuffer.html"
license=(GPL-3.0-or-later)
depends=(
  glibc
  libgcc
)
makedepends=(openssl)
source=(
  https://www.maier-komor.de/software/$pkgname/$pkgname-$pkgver.tgz
)
sha512sums=('5e78500dcfe1f871a2e7209d0b632fc89c7dc908bcfa512253fcc46f730ba8b9ec2fdebfa84c32bfb3641500ce865cda348259b0422fb3fee5b340d320e04224')
b2sums=('2b2be39e1fbcad45714653eba448cf81c241915e8dc40743163e0404287cd3fe23e6c2b7d34a367db67306475335a95fb26f1fdf370ef3027995040fe9259e4d')

prepare() {
  cd $pkgname-$pkgver
  autoreconf -fiv
}

build() {
  cd $pkgname-$pkgver
  ./configure --prefix=/usr --sysconfdir=/etc
  make
}

check() {
  make -k check -C $pkgname-$pkgver
}

package() {
  depends+=(
    openssl libcrypto.so
  )

  make DESTDIR="$pkgdir/" install -C $pkgname-$pkgver
}
