pkgname=jetring
pkgver=0.31
pkgrel=1
pkgdesc="gpg keyring maintenance using changesets"
arch=('any')
url="https://packages.debian.org/sid/jetring"
license=('GPL')
makedepends=('git')
depends=('gnupg' 'perl')
source=("git+https://salsa.debian.org/debian/jetring.git#tag=debian/$pkgver")
sha512sums=('e5f183294f5fdcc29d8cc4738c75994c65941df6b5442811246ea57d610b28a39c05b1bfc07413062adc4fbe24b215c0521c812f8e2826a7e35d048e998bc227')

package() {
  cd $pkgname
  make DESTDIR="$pkgdir" install
}

