# Maintainer: Maxime Gauduin <alucryd@archlinux.org>

pkgname=pantheon-applications-menu
pkgver=8.0.4
pkgrel=1
pkgdesc='The Pantheon Application Menu'
arch=(x86_64)
url=https://github.com/elementary/applications-menu
license=(GPL-3.0-only)
groups=(pantheon)
depends=(
  dconf
  gdk-pixbuf2
  glib2
  glibc
  gtk3
  json-glib
  libgee
  libgranite.so
  libhandy-1.so
  libswitchboard-3.so
  wingpanel
  plank
  zeitgeist
)
makedepends=(
  git
  meson
  vala
)
_tag=eb1416985bea6eea43cdcc84a4aea4cc8498134a
source=(pantheon-applications-menu::git+https://github.com/elementary/applications-menu.git#tag=${_tag})
b2sums=('efae6864298c67fc2a402e88129b7d0f788ed96cbbdf2719de9508bbc54a387a681b2b5ea8382d6d4e9b198d313ae5a5022fc3b62c4746ea7592d27dadcbee62')

pkgver() {
  cd pantheon-applications-menu
  git describe --tags | sed 's/-/.r/; s/-g/./'
}

build() {
  arch-meson pantheon-applications-menu build
  ninja -C build
}

package() {
  DESTDIR="${pkgdir}" meson install -C build
}

