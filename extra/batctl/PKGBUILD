pkgname=batctl
pkgver=2026.0
_advver=$pkgver
pkgrel=1
pkgdesc='B.A.T.M.A.N. advanced control and management tool'
arch=('x86_64')
url='http://www.open-mesh.net/'
license=('GPL-2.0-only AND MIT')
depends=('libnl')
source=("http://downloads.open-mesh.net/batman/releases/batman-adv-$_advver/batctl-$pkgver.tar.gz"{,.asc})
sha512sums=('7a8a11f8d8b90d527472824361caa348713caa4e04a3fae798e958f5492221116237c1e29b0960f61173c08fe34d582cfa1f337826b18e18417269720ab44159'
            'SKIP')
validpgpkeys=('2DE9541A85CC87D5D9836D5E0C8A47A2ABD72DF9')  # Simon Wunderlich

build(){
  cd batctl-$pkgver
  make
}

package() {
  cd batctl-$pkgver
  make DESTDIR="$pkgdir" PREFIX=/usr SBINDIR=/usr/bin install
  install -Dm644 LICENSES/preferred/MIT -t $pkgdir/usr/share/licenses/$pkgname/
}
