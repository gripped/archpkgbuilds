pkgname=perl-libintl-perl
pkgver=1.36
pkgrel=1
pkgdesc="Perl Module: Localization support"
arch=('x86_64')
license=('GPL-3.0-or-later')
url="https://search.cpan.org/dist/libintl-perl"
depends=('coreutils' 'gettext' 'perl')
makedepends=('git')
options=('!emptydirs')
source=("git+https://github.com/gflohr/libintl-perl.git#tag=v$pkgver")
sha512sums=('52ad7593d06053a2cd0673b35c3ee4c3aca1fd186a781895b1d077a3a239f634527a67a396cdcd4fbe8f3f7f7bf1b360be547dfcc6f997dc71fa50e7e10dfaaa')

build() {
  cd libintl-perl
  perl Makefile.PL INSTALLDIRS=vendor
  make
}

check() {
  cd libintl-perl
  make test
}

package() {
  cd libintl-perl
  PERL_USE_UNSAFE_INC=1 \
  make install DESTDIR="$pkgdir"
}
