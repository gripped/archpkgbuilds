# Contributor: Daniel J Griffiths <ghost1227@archlinux.us>
# Contributor: schuay <jakob.gruber@gmail.com>

pkgname=puzzles
pkgver=20260309.06e37f1
pkgrel=1
_commit=${pkgver##*.}
pkgdesc="Simon Tatham's Portable Puzzle Collection"
arch=(x86_64)
url='https://www.chiark.greenend.org.uk/~sgtatham/puzzles/'
license=(MIT)
depends=(cairo
         gdk-pixbuf2
         glib2
         glibc
         gtk3
         pango)
makedepends=(cmake
             git
             halibut
             imagemagick)
source=(git+https://git.tartarus.org/simon/puzzles.git#commit=$_commit)
sha256sums=('3bbb3eb78557a5604ed518e887db26cc16b3c6e8919051c42964b05e11cf81d0')

build() {
  cmake -B build -S puzzles \
   -DCMAKE_INSTALL_PREFIX=/usr \
   -DNAME_PREFIX=puzzles-
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 puzzles/LICENCE "$pkgdir"/usr/share/licenses/$pkgname/LICENSE
}
