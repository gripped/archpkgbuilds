# Maintainer: Maxime Gauduin <alucryd@archlinux.org>

pkgname=switchboard-plug-wacom
pkgver=8.0.2
pkgrel=1
pkgdesc='Switchboard wacom Plug'
arch=(x86_64)
url=https://github.com/elementary/switchboard-plug-wacom
license=(GPL-3.0-only)
groups=(pantheon)
depends=(
  cairo
  glib2
  glibc
  gtk4
  libadwaita-1.so
  libgee
  libgranite-7.so
  libgudev-1.0.so
  libswitchboard-3.so
  libwacom
  libx11
  libxi
)
makedepends=(
  git
  meson
  vala
)
_tag=237693e948292dab61458ba7a16eb4db6e823432
source=(git+https://github.com/elementary/switchboard-plug-wacom.git#tag=${_tag})
sha256sums=('f59f2aaae67efc028061a3e4a7d900e48893f220288b0d6194c217db0443eb2a')

pkgver() {
  cd switchboard-plug-wacom
  git describe --tags
}

build() {
  arch-meson switchboard-plug-wacom build
  ninja -C build
}

package() {
  DESTDIR="${pkgdir}" ninja -C build install
}

