pkgname=ibus-libpinyin
pkgver=1.16.0
pkgrel=1
pkgdesc="Intelligent Pinyin engine based on libpinyin for IBus"
arch=('x86_64')
license=('GPL-3.0-or-later')
url="https://github.com/libpinyin/ibus-libpinyin"
depends=('ibus' 'libpinyin' 'libnotify' 'libsoup3' 'lua' 'opencc' 'python-pyxdg')
makedepends=('boost' 'git' 'gnome-common' 'intltool')
source=("git+https://github.com/libpinyin/ibus-libpinyin.git#tag=$pkgver")
sha512sums=('6ddec139ebde2dfe5ecaf6b94ac97c7b93baa8f04f6327816b11775a545d2a18af3789d75871278dab28bcac83c7073f6916fff8b6a3bc2c4ca7bd9e4407254d')

build() {
  cd $pkgname
  ./autogen.sh --prefix=/usr --libexecdir=/usr/lib/$pkgname --enable-boost --enable-opencc --enable-cloud-input-mode
  make
}

check() {
  make -C $pkgname check
}

package() {
  cd $pkgname
  make NO_INDEX=true DESTDIR="$pkgdir" install
}
