# Maintainer: David Runge <dvzrv@archlinux.org>

pkgbase=erofs-utils
pkgname=(erofs-utils erofsfuse)
pkgver=1.9.1
pkgrel=1
pkgdesc="Userspace utilities for linux-erofs file system"
arch=(x86_64)
url="https://git.kernel.org/pub/scm/linux/kernel/git/xiang/erofs-utils.git"
license=(
  Apache-2.0
  GPL-2.0-or-later
)
makedepends=(
  curl
  fuse2
  glibc
  libdeflate
  lz4
  openssl
  util-linux
  xxhash
  xz
  zlib
  zstd
)
source=($url/snapshot/$pkgname-$pkgver.tar.gz)
sha512sums=('c66ac253e319886fc41e96813de2edb4281317df6477a8ea71a4af49d5750991964347d533a9be825daf2320370141859e3643c52abbac6bfabdd477f7365ebf')
b2sums=('0e3d827e28751f22aa10d32c925debe064cb58cabb68d81d0c9825fd4d0b142cbc8da3bf5c6cda1d68b2a61c216a81f1a2bfa6cdae8e4cbb32abd5489f57c4ec')

prepare() {
  cd $pkgname-$pkgver
  autoreconf -fiv
}

build() {
  local configure_options=(
    --enable-fuse
    --enable-lzma
    --enable-multithreading
    --prefix=/usr
    --sbindir=/usr/bin/
    --with-libdeflate
  )

  cd $pkgname-$pkgver
  MAX_BLOCK_SIZE=65536 ./configure "${configure_options[@]}"
  # prevent excessive overlinking due to libtool
  sed -i -e 's/ -shared / -Wl,-O1,--as-needed\0/g' libtool
  make
}

check() {
  make -k check -C $pkgname-$pkgver
}

_pick() {
  local p="$1" f d; shift
  for f; do
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -vp "$(dirname "$d")"
    mv -v "$f" "$d"
    rmdir -vp --ignore-fail-on-non-empty "$(dirname "$f")"
  done
}

package_erofs-utils() {
  depends+=(
    curl libcurl.so
    glibc
    libdeflate libdeflate.so
    lz4 liblz4.so
    openssl libcrypto.so
    util-linux libuuid.so
    xxhash libxxhash.so
    xz liblzma.so
    zstd libzstd.so
    zlib libz.so
  )
  optdepends=(
    'erofsfuse: for FUSE file system client'
  )

  make DESTDIR="$pkgdir/" install -C $pkgname-$pkgver
  install -vDm 644 $pkgname-$pkgver/{AUTHORS,ChangeLog,README} -t "$pkgdir/usr/share/doc/$pkgname/"

  cd "$pkgdir"
  _pick erofsfuse usr/bin/erofsfuse
  _pick erofsfuse usr/share/man/man1/erofsfuse*
}

package_erofsfuse() {
  pkgdesc="FUSE file system client for erofs file system"
  depends+=(
    fuse2
    glibc
    libdeflate libdeflate.so
    lz4 liblz4.so
    xxhash libxxhash.so
    xz liblzma.so
    zstd libzstd.so
  )

  mv -v $pkgname/* "$pkgdir"
  install -vDm 644 $pkgbase-$pkgver/{AUTHORS,ChangeLog,README} -t "$pkgdir/usr/share/doc/$pkgname/"
}
