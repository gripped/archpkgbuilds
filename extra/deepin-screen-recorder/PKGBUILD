pkgname=deepin-screen-recorder
pkgver=6.5.2
pkgrel=1
pkgdesc='Deepin Screen Recorder'
arch=('x86_64')
url="https://github.com/linuxdeepin/deepin-screen-recorder"
license=('GPL-3.0-or-later')
depends=('deepin-qt6integration' 'deepin-qt-dbus-factory' 'deepin-tray-loader' 'dtk6core' 'dtk6gui' 'dtk6widget'
         'qt6-base' 'qt6-multimedia' 'qt6-wayland' 'deepin-turbo' 'ffmpeg4.4' 'libxtst' 'opencv'
         'dconf' 'libprocps' 'libxext' 'libx11' 'libxfixes' 'portaudio' 'deepin-image-editor' 'gcc-libs')
makedepends=('git' 'deepin-tray-loader' 'qt6-tools')
optdepends=('deepin-shortcut-viewer: for shortcut display')
provides=('deepin-screenshot')
conflicts=('deepin-screenshot')
groups=('deepin-extra')
source=("git+https://github.com/linuxdeepin/deepin-screen-recorder.git#tag=$pkgver"
         libv4l-1.30.patch)
sha512sums=('781e3606bd38f426186a019f3b1033d6af6c1da41dd77c50b8b9dbcd4428a62aa41951e5841196916e4d9e1933955bbf4a8f7b515404e45273198c6f9caec6c1'
            'b8527bbf18b78b530507ed7725218db88f3ae4ed6abb700f6430903421e188456d7f0695f680461376d403c9227bc0234578d909f29399a4072a13a042d524cb')

prepare() {
  cd deepin-screen-recorder
  # Revert opencv -> opencv-mobile change, because opencv-mobile is not available in Arch
  sed -i 's|opencv_mobile|opencv4|;s|-lopencv_small|-lopencv_core -lopencv_imgproc|' src/src.pro

  # https://github.com/linuxdeepin/developer-center/issues/3035
  sed -i "s|/etc/os-version|/etc/uos-version|" src/src.pro

  # OpenCV 4 compatibility
  sed -i '/#include<opencv2/i #include <opencv2/imgproc/types_c.h>' src/utils/pixmergethread.h

  # Remove non-existent resources.qrc reference
  sed -i '/..\/resources.qrc/d' src/src.pro

  patch -p1 -i ../libv4l-1.30.patch
}

build(){
  cd deepin-screen-recorder
  export PKG_CONFIG_PATH='/usr/lib/ffmpeg4.4/pkgconfig'
  qmake6 PREFIX=/usr
  CFLAGS+=" -Wno-implicit-function-declaration -I/usr/include/ffmpeg4.4/" \
  make
}

package() {
  cd deepin-screen-recorder
  make INSTALL_ROOT="$pkgdir" install
}
