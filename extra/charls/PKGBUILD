# Maintainer: Jakub Klinkovský <lahwaacz at archlinux dot org>

pkgname=charls
pkgver=2.4.3
pkgrel=1
pkgdesc="A C++ JPEG-LS library implementation"
arch=(x86_64)
url="https://github.com/team-charls/charls"
license=(BSD-3-Clause)
depends=(
  glibc
  libgcc
  libstdc++
)
makedepends=(
  cmake
  ninja
)
provides=(
  libcharls.so
)
source=($pkgname-$pkgver.tar.gz::$url/archive/refs/tags/$pkgver.tar.gz)
b2sums=('a2655be530771457838bb7757077679b22fbc85b87aea4d479dc9ffd4440644c913b1f8f3e78ab2a37e4c8d37259a93bda5d63cae04d09ec60ab686251171690')

build() {
  local cmake_options=(
    -B build
    -S $pkgname-$pkgver
    -G Ninja
    -W no-dev
    -DCMAKE_BUILD_TYPE=None
    -DCMAKE_INSTALL_PREFIX=/usr
    -DBUILD_SHARED_LIBS=ON
  )
  cmake "${cmake_options[@]}"
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -vDm 644 $pkgname-$pkgver/LICENSE.md -t "$pkgdir"/usr/share/licenses/$pkgname/
}
