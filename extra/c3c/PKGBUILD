# Contributor: Eduardo Jose Gomez Hernandez <eduardo@edujgh.net>

pkgname=c3c
pkgver=0.7.10
pkgrel=2
pkgdesc='Compiler for the C3 language'
arch=(x86_64)
url='https://github.com/c3lang/c3c'
license=(LGPL-3.0-or-later MIT)
depends=(curl lld llvm-libs libstdc++ glibc)
makedepends=(clang cmake git libedit llvm)
source=("git+$url#tag=v$pkgver"
        "llvm-22.patch")
b2sums=('70e73c10eec628ff41fb0423ae073a9491643bd21424b38dc0d424870cfb6dff39ea08db1a0580f0f10d9dbd3565586772c9e94f17a4903ac8c66331f774dead'
        '0f801703c61d3cbcd2feccff64e4a2568824ca880ac482cde65fe55094d2ed48821cc674d7f36a3347dca243627895726d9bb3c9b03a8eb113be5e39e159fb6c')

prepare() {
  cd $pkgname
  patch -Np1 < ../llvm-22.patch
  # Pretend that git is missing and define the git hash manually
  sed -i '/find_package(Git /d' CMakeLists.txt git_hash.cmake
  sed -i "s/unknown/$(git rev-parse HEAD)/g" git_hash.cmake
}

build() {
  cmake \
    -B build \
    -D C3_LINK_DYNAMIC=ON \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_C_FLAGS_RELEASE="$CFLAGS" \
    -D CMAKE_CXX_FLAGS_RELEASE="$CXXFLAGS" \
    -S $pkgname
  make -C build
}

package() {
  install -Dm755 build/c3c "$pkgdir/usr/lib/$pkgname/c3c"
  cp -r build/lib "$pkgdir/usr/lib/$pkgname/lib"
  install -d "$pkgdir/usr/bin"
  ln -s "/usr/lib/$pkgname/c3c" "$pkgdir/usr/bin/c3c"
  cd $pkgname
  install -Dm644 LICENSE -t "$pkgdir/usr/share/licenses/$pkgname"
  install -Dm644 LICENSE_SRC -t "$pkgdir/usr/share/licenses/$pkgname"
}
