pkgbase=dtkcore
pkgname=(dtkcore dtk6core)
pkgver=6.7.31
pkgrel=1
epoch=1
pkgdesc='DTK core modules'
arch=('x86_64')
url="https://github.com/linuxdeepin/dtkcore"
license=('LGPL-3.0-or-later')
groups=('deepin')
makedepends=('git' 'cmake' 'ninja' 'qt5-tools' 'qt6-tools' 'gtest' 'doxygen'
             'dbus' 'deepin-desktop-base' 'dtkcommon' 'dtklog' 'dtk6log'
             'gsettings-qt' 'icu' 'lshw' 'qt5-base' 'qt6-base' 'uchardet')
source=("git+https://github.com/linuxdeepin/dtkcore.git#tag=$pkgver")
sha512sums=('0273634c4577629769429917e2b8cfd78eccd0a24ba7d6ef025550e9b2e7ff8890f401ff7bf9e32ecddc272daa17297bda94491236de247d060cfa223bea5ece')

prepare() {
  cd dtkcore
  sed -i 's|/etc/os-version|/etc/uos-version|' src/dsysinfo.cpp
}

build() {
  cd dtkcore

  # Build Qt5 variant (dtkcore)
  cmake . -Bbuild-qt5 -GNinja \
    -DDTK5=ON \
    -DBUILD_WITH_SYSTEMD=ON \
    -DBUILD_TESTING=ON \
    -DMKSPECS_INSTALL_DIR=lib/qt/mkspecs/modules \
    -DFEATURES_INSTALL_DIR=lib/qt/mkspecs/features \
    -DQCH_INSTALL_DESTINATION=share/doc/qt \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_INSTALL_LIBEXECDIR=lib \
    -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build-qt5

  # Build Qt6 variant (dtk6core)
  cmake . -Bbuild-qt6 -GNinja \
    -DDTK5=OFF \
    -DBUILD_WITH_SYSTEMD=ON \
    -DBUILD_DOCS=ON \
    -DBUILD_TESTING=ON \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_INSTALL_LIBEXECDIR=lib \
    -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build-qt6
}

check() {
  cd dtkcore
  ninja -C build-qt5 test || echo "Qt5 tests failed"
  ninja -C build-qt6 test || echo "Qt6 tests failed"
}

package_dtkcore() {
  pkgdesc='DTK core modules (Qt5 build)'
  depends=('dbus' 'deepin-desktop-base' 'dtkcommon' 'dtklog' 'glibc' 'gsettings-qt' 'icu'
           'libgcc' 'libstdc++' 'lshw' 'qt5-base' 'uchardet')

  cd dtkcore
  DESTDIR="$pkgdir" ninja -C build-qt5 install
}

package_dtk6core() {
  pkgdesc='DTK core modules (Qt6 build)'
  depends=('dbus' 'deepin-desktop-base' 'dtkcommon' 'dtk6log' 'glibc' 'icu' 'libgcc' 'libstdc++'
           'lshw' 'qt6-base' 'uchardet')

  cd dtkcore
  DESTDIR="$pkgdir" ninja -C build-qt6 install
}
