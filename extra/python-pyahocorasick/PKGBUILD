# Maintainer: kpcyrd <kpcyrd[at]archlinux[dot]org>

pkgname=python-pyahocorasick
_name=pyahocorasick
pkgver=2.3.0
pkgrel=1
pkgdesc='Python module (C extension and plain python) implementing Aho-Corasick algorithm'
url='https://github.com/WojciechMula/pyahocorasick'
arch=('x86_64')
license=('BSD-3-Clause')
depends=(
  glibc
  python
)
makedepends=('python-build' 'python-installer' 'python-setuptools' 'python-wheel')
source=(https://files.pythonhosted.org/packages/source/${_name::1}/$_name/$_name-$pkgver.tar.gz)
b2sums=('372a73052e77cac0a95892bb0ae5527f3fc0db4954aa2c21951c8c171bbdb549c4b3da0f31656b2bea6e8404dbbc053718b5621a5b51fbce1f1f46844a2f4c03')

build() {
  cd "${_name}-${pkgver}"
  python -m build --wheel --no-isolation
}

check() {
  cd "${_name}-${pkgver}"
  PYTHONPATH=. python -c 'import src'
}

package() {
  cd "${_name}-${pkgver}"
  python -m installer --destdir="${pkgdir}" dist/*.whl
  install -D LICENSE -t "${pkgdir}/usr/share/licenses/${pkgname}"
}

