# Maintainer: Felix Yan <felixonmars@archlinux.org>

pkgname=deepin-turbo
pkgver=0.0.6.1
pkgrel=1
pkgdesc='A daemon that helps to launch applications faster'
arch=('x86_64')
url="https://github.com/linuxdeepin/deepin-turbo"
license=('GPL-3.0-or-later')
depends=('dtkwidget')
makedepends=('git' 'cmake' 'ninja')
groups=('deepin')
source=("git+https://github.com/linuxdeepin/deepin-turbo.git#tag=$pkgver")
sha512sums=('c58d27f1467b6f126d23c745d08652b3c99fe4a27a94abf4c4fe2b19bc6fa3b07bab7f7a42f64deff538d81085bd1da4e1b66db81c19d0e159276e6b58594644')

prepare() {
  cd deepin-turbo
  sed -i 's/DtkWidget5\.5/DtkWidget/g' src/booster-dtkwidget/CMakeLists.txt
}

build() {
  cd deepin-turbo
  cmake -GNinja -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_INSTALL_LIBDIR=lib -DCMAKE_POLICY_VERSION_MINIMUM=3.5 .
  ninja
}

package() {
  cd deepin-turbo
  DESTDIR="$pkgdir" ninja install
}
