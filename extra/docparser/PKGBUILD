# Maintainer: Felix Yan <felixonmars@archlinux.org>

pkgname=docparser
pkgver=1.0.8
pkgrel=1
pkgdesc='A document parser library ported from document2html'
arch=('x86_64')
url="https://github.com/linuxdeepin/docparser"
license=('LGPL-3.0-or-later')
depends=('poppler' 'libzip' 'pugixml')
makedepends=('git' 'qt5-tools')
groups=('deepin')
source=("git+https://github.com/linuxdeepin/docparser.git#tag=$pkgver")
b2sums=('684dc08d6b57100fd2f21a8e9c032d4b14d7ea29795495dad1e659a3fee7eea366eac587daddf74ee0808ecb4bd6eba5db5ddce3f4ce1e0b3dc7702d00081355')

build() {
  cd docparser
  qmake-qt5 PREFIX=/usr
  make
}

package() {
  cd docparser
  make INSTALL_ROOT="$pkgdir" install
}
