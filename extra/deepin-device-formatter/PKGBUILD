# Maintainer: Felix Yan <felixonmars@archlinux.org>

pkgname=deepin-device-formatter
pkgver=0.0.1.18
pkgrel=1
pkgdesc='A simple graphical interface for creating file system in a block device'
arch=('x86_64')
url="https://github.com/linuxdeepin/dde-device-formatter"
license=('GPL-3.0-or-later')
depends=('deepin-qt5integration' 'dtkcore' 'dtkgui' 'dtkwidget' 'qt5-base' 'qt5-x11extras'
         'libx11' 'udisks2-qt5' 'gcc-libs')
makedepends=('git' 'deepin-gettext-tools' 'qt5-tools')
groups=('deepin-extra')
source=("git+https://github.com/linuxdeepin/dde-device-formatter.git#tag=$pkgver")
sha512sums=('ce5eef9b674f4bb00a0a1edf370431285a2dc0d10ab3332bd833bfb32ce0114ba7d03de5f5570108ee3adb46523be4e55e4b3cae9888fa7c0cad94af3e64e5dc')

build(){
  cd dde-device-formatter
  qmake-qt5 PREFIX=/usr
  make
}

package() {
  cd dde-device-formatter
  make INSTALL_ROOT="$pkgdir" install
}
